# HMS Frontend Environment Variables
# Copy this file to .env and replace with your actual values if needed.
# DO NOT commit .env to the repository.

# Backend API URL (defaults to http://localhost:3000/api in dev, /api in prod)
VITE_API_URL="http://localhost:3000/api"

# Dashboard population mode:
# off      = never use synthetic dashboard data
# fallback = use deterministic synthetic values only when a supported live metric is empty/unavailable
# force    = use the complete synthetic scenario for design review
# Production defaults to off even when these variables are omitted.
VITE_DASHBOARD_DEMO_MODE="fallback"
VITE_DASHBOARD_DEMO_SEED="20260710"
VITE_DASHBOARD_DEMO_PROFILE="normal"
