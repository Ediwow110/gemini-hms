# HMS Backend Environment Variables
# Copy this file to .env and replace with your actual values.
# DO NOT commit .env to the repository.

# Database connection string
# point to your own local, staging, or test PostgreSQL database.
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/hms_db?schema=public"

# JWT Secret for authentication
# Must be at least 32 characters long for production security.
JWT_SECRET="CHANGE_ME_TO_A_REAL_32_PLUS_CHARACTER_SECRET"

# Master MFA Key for TOTP secret encryption
# Must be at least 32 characters long. Required at startup.
MASTER_MFA_KEY="CHANGE_ME_TO_A_REAL_32_PLUS_CHARACTER_SECRET"

# CORS allowed origins (comma-separated)
# Frontend dev server and any other allowed origins.
CORS_ALLOWED_ORIGINS="http://localhost:5173"

# Cookie SameSite attribute (optional, defaults to 'strict')
# Staging/split-origin deployments (e.g. Vercel frontend + Render backend): set to 'none'
#   which forces secure:true and allows cross-origin cookie sending for fetch/XHR.
# IMPORTANT: 'none' broadens CSRF exposure, but the existing csrf_token cookie +
#   X-CSRF-Token header mechanism still provides defense-in-depth.
# Production: leave unset (defaults to 'strict') unless split-origin requires otherwise.
# COOKIE_SAME_SITE="strict"

# Backend server port (defaults to 3000 if not set)
PORT="3000"

# Node environment (development, production, test)
NODE_ENV="development"

# Notification Providers (optional, defaults to 'mock')
# EMAIL_PROVIDER="mock" # or "ses", "mailrelay"
# SMS_PROVIDER="mock" # or "semaphore"

# External API Keys (if using real providers)
# MAILRELAY_API_KEY=""
# MAILRELAY_SMTP_PASS=""
# MAILRELAY_SENDER_EMAIL=""
# MAILRELAY_SENDER_NAME=""
# AWS_REGION=""
# SES_SENDER_EMAIL=""
# SEMAPHORE_API_KEY=""
