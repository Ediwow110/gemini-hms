# HMS Backend Environment Variables
# Copy this file to .env and replace with your actual values.
# DO NOT commit .env to the repository.

# Database connection string
# point to your own local, staging, or test PostgreSQL database.
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/hms_db?schema=public"

# JWT Secret for authentication
# Must be at least 32 characters long for production security.
JWT_SECRET="CHANGE_ME_TO_A_REAL_32_PLUS_CHARACTER_SECRET"

# Notification Providers (optional, defaults to 'mock')
# EMAIL_PROVIDER="mock" # or "ses", "mailrelay"
# SMS_PROVIDER="mock" # or "semaphore"

# External API Keys (if using real providers)
# MAILRELAY_API_KEY=""
# MAILRELAY_SMTP_PASS=""
# MAILRELAY_SENDER_EMAIL=""
# MAILRELAY_SENDER_NAME=""
# AWS_REGION=""
# SES_SENDER_EMAIL=""
# SEMAPHORE_API_KEY=""
