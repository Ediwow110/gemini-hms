# HMS Backend Environment Variables
# Copy this file to .env and replace with your actual values.
# DO NOT commit .env to the repository.

# Database connection string
# point to your own local, staging, or test PostgreSQL database.
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/hms_db?schema=public"

# JWT Secret for authentication
# Must be at least 32 characters long for production security.
JWT_SECRET="CHANGE_ME_TO_A_REAL_32_PLUS_CHARACTER_SECRET"

# Master MFA Key for TOTP secret encryption
# Must be at least 32 characters long. Required at startup.
MASTER_MFA_KEY="CHANGE_ME_TO_A_REAL_32_PLUS_CHARACTER_SECRET"

# CORS allowed origins (comma-separated)
# Frontend dev server and any other allowed origins.
CORS_ALLOWED_ORIGINS="http://localhost:5173"

# Cookie SameSite attribute (optional, defaults to 'strict')
# Staging/split-origin deployments (e.g. Vercel frontend + Render backend): set to 'none'
#   which forces secure:true and allows cross-origin cookie sending for fetch/XHR.
# IMPORTANT: 'none' broadens CSRF exposure, but the existing csrf_token cookie +
#   X-CSRF-Token header mechanism still provides defense-in-depth.
# Production: leave unset (defaults to 'strict') unless split-origin requires otherwise.
# COOKIE_SAME_SITE="strict"

# Backend server port (defaults to 3000 if not set)
PORT="3000"

# Node environment (development, production, test)
NODE_ENV="development"

# Storage Provider Configuration
# STORAGE_DRIVER: "s3" | "local" (default: "local" for development)
STORAGE_DRIVER="local"

# S3/MinIO Configuration (required when STORAGE_DRIVER=s3)
# AWS_S3_REGION: e.g., "us-east-1"
# AWS_S3_BUCKET: e.g., "hms-patient-documents"
# AWS_S3_ACCESS_KEY_ID: "<access-key>"
# AWS_S3_SECRET_ACCESS_KEY: "<secret-key>"
# AWS_S3_ENDPOINT: (Optional) For MinIO, e.g., "http://localhost:9000"
# AWS_S3_FORCE_PATH_STYLE: (Optional) "true" for MinIO, "false" for AWS S3
# AWS_S3_PUBLIC_URL_BASE: (Optional) Public URL base for signed URLs, e.g., "https://cdn.example.com"

# Payment Gateway Configuration
# PAYMENT_GATEWAY_PROVIDER: "stripe" | "xendit" | "mock" (default: "mock")
PAYMENT_GATEWAY_PROVIDER="mock"

# Stripe Configuration (required when PAYMENT_GATEWAY_PROVIDER=stripe)
# STRIPE_SECRET_KEY: "sk_test_..."
# STRIPE_WEBHOOK_SECRET: "whsec_..."
# STRIPE_API_VERSION: (Optional) e.g., "2023-10-16"

# Notification Providers
# Local dev (NODE_ENV=development): defaults to mock — console-only, no real delivery.
# Staging/production (NODE_ENV=production): mock is REJECTED at startup; you MUST set
# non-mock providers before deploy (see docker-compose.staging.yml / docker-compose.prod.yml).
# EMAIL_PROVIDER="mock"        # dev only; use "ses" or "mailrelay" for staging/prod
# SMS_PROVIDER="mock"          # dev only; use "semaphore" for staging/prod
#
# Provider credentials (required for the chosen provider; send methods are honest stubs
# until real HTTP/SDK integration is wired — notifications will mark FAILED, not fake SENT):
# MAILRELAY_API_KEY=""
# MAILRELAY_SMTP_PASS=""
# MAILRELAY_SENDER_EMAIL=""
# MAILRELAY_SENDER_NAME=""
# AWS_REGION=""
# SES_SENDER_EMAIL=""
# SEMAPHORE_API_KEY=""
