// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  branches             Branch[]
  users                User[]
  patients             Patient[]
  roles                Role[]
  permissions          Permission[]
  approvalRequests     ApprovalRequest[]
  notifications        Notification[]
  files                File[]
  cashierSessions      CashierSession[]
  numberingSequences   NumberingSequence[]
  serviceCategories    ServiceCategory[]
  serviceItems         ServiceItem[]
  servicePrices        ServicePrice[]
  orders               Order[]
  orderItems           OrderItem[]
  invoices             Invoice[]
  payments             Payment[]
  labResults           LabResult[]
  radiologyReports     RadiologyReport[]
  auditLogs            AuditLog[]
  inventoryItems       InventoryItem[]
  branchStocks         BranchStock[]
  stockLogs            StockLog[]
  departments          Department[]
  employees            Employee[]
  employeeBranches     EmployeeBranch[]
  payslips             Payslip[]
  queueEntries         QueueEntry[]
  hmoPartners          HmoPartner[]
  claims               Claim[]
  userBranches         UserBranch[]
  reportExports        ReportExport[]
  patientMergeRequests PatientMergeRequest[]
  idempotencyRecords   IdempotencyRecord[]
  encounters           Encounter[]
  prescriptions        Prescription[]
  referrals            Referral[]
  patientUsers         PatientUser[]
  insuranceClaims      InsuranceClaim[]
  ledgerEntries        LedgerEntry[]
  triageRecords        Triage[]
  clinicalOrderItems   ClinicalOrderItem[]
  labSpecimens         LabSpecimen[]
  marketplaceListings  MarketplaceListing[]

  suppliers                   Supplier[]
  purchaseRequests            PurchaseRequest[]
  purchaseOrders              PurchaseOrder[]
  receivingRecords            ReceivingRecord[]
  referrers                   Referrer[]
  referralRecords             ReferralRecord[]
  slaAlerts                   SlaAlert[]
  cptCodes                    CptCode[]
  labTestDefinitions          LabTestDefinition[]
  labTestParameterDefinitions LabTestParameterDefinition[]
  rfqs                        RFQ[]
  quotes                      Quote[]
  salesOrders                 SalesOrder[]
  shipments                   Shipment[]
  deliveryJobs                DeliveryJob[]
  installationJobs            InstallationJob[]
  assets                      Asset[]
  supportTickets              SupportTicket[]
  nurseTasks                  NurseTask[]
  refillRequests              RefillRequest[]
  medicalRecordRequests       MedicalRecordRequest[]
  notificationOutbox          NotificationOutbox[]
  paymentVoids                PaymentVoid[]
  refunds                     Refund[]
  cashierLedgerEntries        CashierLedgerEntry[]

  @@map("tenants")
}

model Branch {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  name      String
  code      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant           Tenant           @relation(fields: [tenantId], references: [id])
  orders           Order[]
  userBranches     UserBranch[]
  branchStocks     BranchStock[]
  stockLogs        StockLog[]
  employeeBranches EmployeeBranch[]
  payslips         Payslip[]
  encounters       Encounter[]
  prescriptions    Prescription[]
  referrals        Referral[]
  servicePrices    ServicePrice[]
  insuranceClaims  InsuranceClaim[]
  ledgerEntries    LedgerEntry[]
  employees        Employee[]
  triageRecords    Triage[]
  labSpecimens     LabSpecimen[]
  rfqs             RFQ[]
  supportTickets   SupportTicket[]
  nurseTasks       NurseTask[]
  payments         Payment[]
  paymentVoids     PaymentVoid[]
  refunds          Refund[]
  sessions         Session[]

  @@map("branches")
}

model User {
  id                  String    @id @default(uuid()) @db.Uuid
  tenantId            String    @map("tenant_id") @db.Uuid
  supplierId          String?   @map("supplier_id") @db.Uuid
  email               String
  passwordHash        String    @map("password_hash")
  mfaEnabled          Boolean   @default(false) @map("is_mfa_enabled")
  mfaSecret           String?   @map("mfa_secret")
  status              String    @default("ACTIVE")
  deactivatedAt       DateTime? @map("deactivated_at")
  deactivatedReason   String?   @map("deactivated_reason")
  tokenVersion        Int       @default(0) @map("token_version")
  failedLoginAttempts Int       @default(0) @map("failed_login_attempts")
  lockedUntil         DateTime? @map("locked_until")
  isSystem            Boolean   @default(false) @map("is_system")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  tenant                  Tenant                @relation(fields: [tenantId], references: [id])
  supplier                Supplier?             @relation(fields: [supplierId], references: [id])
  auditLogs               AuditLog[]
  userRoles               UserRole[]
  userBranches            UserBranch[]
  reportExports           ReportExport[]        @relation("RequestedExports")
  decidedExports          ReportExport[]        @relation("DecidedExports")
  requestedApprovals      ApprovalRequest[]     @relation("RequestedApprovals")
  approvedApprovals       ApprovalRequest[]     @relation("ApprovedApprovals")
  mergeRequested          PatientMergeRequest[] @relation("MergeRequested")
  mergeApproved           PatientMergeRequest[] @relation("MergeApproved")
  encountersAttending     Encounter[]           @relation("EncounterAttending")
  encountersAsDoctor      Encounter[]           @relation("EncounterDoctor")
  clinicalNotesAuthor     ClinicalNote[]        @relation("ClinicalNoteAuthor")
  clinicalNotesLocker     ClinicalNote[]        @relation("ClinicalNoteLocker")
  prescriptionsPrescribed Prescription[]        @relation("PrescribedBy")
  prescriptionsDispensed  Prescription[]        @relation("DispensedBy")
  referralsReferred       Referral[]            @relation("ReferredBy")
  requestedOrders         Order[]               @relation("OrderRequestedBy")
  cancelledOrders         Order[]               @relation("OrderCancelledBy")
  sessions                Session[]
  mfaRecoveryCodes        UserMfaRecoveryCode[]
  employees               Employee[]
  deliveryJobs            DeliveryJob[]
  installationJobs        InstallationJob[]
  ticketsReported         SupportTicket[]       @relation("TicketReporter")
  ticketsAssigned         SupportTicket[]       @relation("TicketAssignee")
  nurseTasksAssigned      NurseTask[]           @relation("NurseTaskAssigned")
  nurseTasksCreated       NurseTask[]           @relation("NurseTaskCreated")
  nurseTasksCompleted     NurseTask[]           @relation("NurseTaskCompleted")
  nurseTasksCancelled     NurseTask[]           @relation("NurseTaskCancelled")
  reviewedRefillRequests       RefillRequest[]         @relation("RefillReviewedBy")
  reviewedMedicalRecordRequests MedicalRecordRequest[] @relation("MedRecordReviewedBy")

  @@unique([tenantId, email])
  @@map("users")
}

model UserMfaRecoveryCode {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  codeHash  String    @map("code_hash")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_mfa_recovery_codes")
}

model Session {
  id               String   @id @default(uuid()) @db.Uuid
  userId           String   @map("user_id") @db.Uuid
  tenantId         String   @map("tenant_id") @db.Uuid
  branchId         String?  @map("branch_id") @db.Uuid
  refreshTokenHash String   @unique @map("refresh_token_hash")
  isMfaVerified    Boolean  @default(false) @map("is_mfa_verified")
  expiresAt        DateTime @map("expires_at")
  lastRotatedAt    DateTime @default(now()) @map("last_rotated_at")
  userAgent        String?  @map("user_agent")
  ipAddress        String?  @map("ip_address")

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  branch Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([tenantId])
  @@index([branchId])
  @@map("sessions")
}

model Role {
  id             String    @id @default(uuid()) @db.Uuid
  tenantId       String    @map("tenant_id") @db.Uuid
  name           String
  status         String    @default("ACTIVE")
  isSystem       Boolean   @default(false) @map("is_system")
  archivedAt     DateTime? @map("archived_at")
  archivedReason String?   @map("archived_reason")

  tenant          Tenant           @relation(fields: [tenantId], references: [id])
  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@unique([tenantId, name])
  @@map("roles")
}

model UserRole {
  id            String    @id @default(uuid()) @db.Uuid
  userId        String    @map("user_id") @db.Uuid
  roleId        String    @map("role_id") @db.Uuid
  status        String    @default("ACTIVE")
  revokedAt     DateTime? @map("revoked_at")
  revokedReason String?   @map("revoked_reason")

  user User @relation(fields: [userId], references: [id])
  role Role @relation(fields: [roleId], references: [id])

  @@unique([userId, roleId])
  @@map("user_roles")
}

model UserBranch {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  branchId  String   @map("branch_id") @db.Uuid
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId, branchId])
  @@index([tenantId])
  @@index([userId])
  @@index([branchId])
  @@index([tenantId, userId])
  @@index([tenantId, branchId])
  @@map("user_branches")
}

enum EncounterStatus {
  OPEN
  CLOSED
  CANCELLED
  PLANNED
  ARRIVED
  IN_PROGRESS
  FINISHED
  ENTERED_IN_ERROR
  UNKNOWN
}

enum NoteType {
  CHIEF_COMPLAINT
  PROGRESS
  NURSING
  DISCHARGE
  SOAP
}

model Encounter {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  branchId       String   @map("branch_id") @db.Uuid
  patientId      String   @map("patient_id") @db.Uuid
  attendingId    String?  @map("attending_id") @db.Uuid
  doctorId       String?  @map("doctor_id") @db.Uuid
  encounteredAt  DateTime @default(now()) @map("encountered_at")
  chiefComplaint String   @default("") @map("chief_complaint") @db.Text

  status EncounterStatus @default(OPEN)
  type   String? // OUTPATIENT, INPATIENT, EMERGENCY, etc.

  startedAt DateTime  @default(now()) @map("started_at")
  endedAt   DateTime? @map("ended_at")

  reason String?
  notes  String?

  createdBy     String    @map("created_by") @db.Uuid
  updatedBy     String    @map("updated_by") @db.Uuid
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  archivedAt    DateTime? @map("archived_at")
  archiveReason String?   @map("archive_reason")

  vitals             Vitals[]
  diagnoses          Diagnosis[]
  encounterDiagnoses EncounterDiagnosis[]
  clinicalNotes      ClinicalNote[]
  prescriptions      Prescription[]
  referrals          Referral[]
  triageRecords      Triage[]
  orders             Order[]

  tenant    Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch    Branch  @relation(fields: [branchId], references: [id], onDelete: Cascade)
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  attending User?   @relation("EncounterAttending", fields: [attendingId], references: [id])
  doctor    User?   @relation("EncounterDoctor", fields: [doctorId], references: [id])

  @@index([tenantId, patientId])
  @@index([tenantId, status])
  @@index([tenantId])
  @@index([branchId])
  @@index([patientId])
  @@index([status])
  @@map("encounters")
}

model Vitals {
  id          String @id @default(uuid()) @db.Uuid
  tenantId    String @map("tenant_id") @db.Uuid
  encounterId String @map("encounter_id") @db.Uuid

  temperature Decimal? @db.Decimal(5, 2)
  systolicBp  Int?     @map("systolic_bp")
  diastolicBp Int?     @map("diastolic_bp")
  heartRate   Int?     @map("heart_rate")
  respiratory Int?     @map("respiratory_rate")
  weightKg    Decimal? @map("weight_kg") @db.Decimal(6, 2)

  createdBy   String    @map("created_by") @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at")
  status      String    @default("ACTIVE")
  errorAt     DateTime? @map("error_at")
  errorById   String?   @map("error_by_id") @db.Uuid
  errorReason String?   @map("error_reason")

  encounter Encounter @relation(fields: [encounterId], references: [id], onDelete: Cascade)

  @@index([tenantId, encounterId])
  @@map("vitals")
}

model Triage {
  id                    String    @id @default(uuid()) @db.Uuid
  tenantId              String    @map("tenant_id") @db.Uuid
  branchId              String    @map("branch_id") @db.Uuid
  patientId             String    @map("patient_id") @db.Uuid
  encounterId           String?   @map("encounter_id") @db.Uuid
  queueEntryId          String?   @map("queue_entry_id") @db.Uuid
  acuityLevel           String?   @map("acuity_level")
  chiefComplaintSummary String?   @map("chief_complaint_summary")
  arrivalMode           String?   @map("arrival_mode")
  painScore             Int?      @map("pain_score")
  infectiousRiskFlag    Boolean   @default(false) @map("infectious_risk_flag")
  fallRiskFlag          Boolean   @default(false) @map("fall_risk_flag")
  pregnancyFlag         Boolean   @default(false) @map("pregnancy_flag")
  notes                 String?
  recordedById          String    @map("recorded_by_id") @db.Uuid
  status                String    @default("ACTIVE")
  errorReason           String?   @map("error_reason")
  errorById             String?   @map("error_by_id") @db.Uuid
  errorAt               DateTime? @map("error_at")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch    Branch     @relation(fields: [branchId], references: [id], onDelete: Cascade)
  patient   Patient    @relation(fields: [patientId], references: [id], onDelete: Cascade)
  encounter Encounter? @relation(fields: [encounterId], references: [id], onDelete: SetNull)

  @@index([tenantId, patientId])
  @@index([tenantId, encounterId])
  @@map("triage_records")
}

model Diagnosis {
  id          String @id @default(uuid()) @db.Uuid
  tenantId    String @map("tenant_id") @db.Uuid
  encounterId String @map("encounter_id") @db.Uuid

  icd10Code   String  @map("icd_10_code")
  description String  @db.Text
  isPrimary   Boolean @default(false) @map("is_primary")

  createdBy String   @map("created_by") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  encounter Encounter @relation(fields: [encounterId], references: [id], onDelete: Cascade)

  @@index([tenantId, encounterId])
  @@map("diagnoses")
}

model ClinicalNote {
  id          String @id @default(uuid()) @db.Uuid
  tenantId    String @map("tenant_id") @db.Uuid
  encounterId String @map("encounter_id") @db.Uuid

  noteType NoteType @default(PROGRESS) @map("note_type")
  content  String   @default("") @db.Text

  authorId   String?   @map("author_id") @db.Uuid
  subjective String?   @db.Text
  objective  String?   @db.Text
  assessment String?   @db.Text
  plan       String?   @db.Text
  lockedAt   DateTime? @map("locked_at")
  lockedBy   String?   @map("locked_by") @db.Uuid

  createdBy String    @map("created_by") @db.Uuid
  updatedBy String    @map("updated_by") @db.Uuid
  deletedAt DateTime? @map("deleted_at")
  version   Int       @default(0)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  encounter Encounter @relation(fields: [encounterId], references: [id], onDelete: Cascade)
  author    User?     @relation("ClinicalNoteAuthor", fields: [authorId], references: [id])
  locker    User?     @relation("ClinicalNoteLocker", fields: [lockedBy], references: [id])

  @@index([tenantId, encounterId])
  @@map("clinical_notes")
}

model Icd10Code {
  id          String   @id @default(uuid()) @db.Uuid
  code        String   @unique
  description String   @db.Text
  createdAt   DateTime @default(now()) @map("created_at")

  diagnoses EncounterDiagnosis[]

  @@map("icd_10_codes")
}

model EncounterDiagnosis {
  id           String    @id @default(uuid()) @db.Uuid
  encounterId  String    @map("encounter_id") @db.Uuid
  icd10CodeId  String    @map("icd10_code_id") @db.Uuid
  isPrimary    Boolean   @default(false) @map("is_primary")
  notes        String?   @db.Text
  createdAt    DateTime  @default(now()) @map("created_at")
  deletedAt    DateTime? @map("deleted_at")
  deletedById  String?   @map("deleted_by_id") @db.Uuid
  deleteReason String?   @map("delete_reason")

  encounter Encounter @relation(fields: [encounterId], references: [id], onDelete: Cascade)
  icd10Code Icd10Code @relation(fields: [icd10CodeId], references: [id], onDelete: Cascade)

  @@map("encounter_diagnoses")
}

model Patient {
  id            String    @id @default(uuid()) @db.Uuid
  tenantId      String    @map("tenant_id") @db.Uuid
  patientNumber String    @map("patient_number")
  firstName            String    @map("first_name")
  lastName             String    @map("last_name")
  dob                  DateTime  @db.Date
  normalizedNameDobKey String?   @map("normalized_name_dob_key")
  status               String    @default("ACTIVE")
  createdById          String?   @map("created_by_id") @db.Uuid
  updatedById          String?   @map("updated_by_id") @db.Uuid
  deletedAt            DateTime? @map("deleted_at")
  version              Int       @default(0)
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")
  archivedAt           DateTime? @map("archived_at")
  archiveReason        String?   @map("archive_reason")

  tenant          Tenant           @relation(fields: [tenantId], references: [id])
  orders          Order[]
  encounters      Encounter[]
  prescriptions   Prescription[]
  referrals       Referral[]
  portalUser      PatientUser?
  insuranceClaims InsuranceClaim[]
  triageRecords   Triage[]
  labSpecimens           LabSpecimen[]
  nurseTasks             NurseTask[]
  refillRequests         RefillRequest[]
  medicalRecordRequests  MedicalRecordRequest[]
  notificationOutbox     NotificationOutbox[]

  @@unique([tenantId, id])
  @@unique([tenantId, patientNumber])
  @@unique([tenantId, normalizedNameDobKey])
  @@map("patients")
}

model Order {
  id                 String    @id @default(uuid()) @db.Uuid
  tenantId           String    @map("tenant_id") @db.Uuid
  branchId           String    @map("branch_id") @db.Uuid
  patientId          String    @map("patient_id") @db.Uuid
  orderNumber        String    @map("order_number")
  status             String    @default("DRAFT")
  encounterId        String?   @map("encounter_id") @db.Uuid
  orderType          String?   @map("order_type")
  priority           String?   @default("ROUTINE")
  clinicalIndication String?   @map("clinical_indication")
  requestedById      String?   @map("requested_by_id") @db.Uuid
  requestedAt        DateTime? @map("requested_at")
  cancelledReason    String?   @map("cancelled_reason")
  cancelledById      String?   @map("cancelled_by_id") @db.Uuid
  cancelledAt        DateTime? @map("cancelled_at")
  createdById        String?   @map("created_by_id") @db.Uuid
  updatedById        String?   @map("updated_by_id") @db.Uuid
  deletedAt          DateTime? @map("deleted_at")
  version            Int       @default(0)
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  tenant        Tenant              @relation(fields: [tenantId], references: [id])
  branch        Branch              @relation(fields: [branchId], references: [id])
  patient       Patient             @relation(fields: [patientId], references: [id])
  encounter     Encounter?          @relation(fields: [encounterId], references: [id], onDelete: SetNull)
  requestedBy   User?               @relation("OrderRequestedBy", fields: [requestedById], references: [id], onDelete: SetNull)
  cancelledBy   User?               @relation("OrderCancelledBy", fields: [cancelledById], references: [id], onDelete: SetNull)
  items         OrderItem[]
  clinicalItems ClinicalOrderItem[]
  invoice       Invoice?
  labSpecimen   LabSpecimen?
  labResult       LabResult?
  radiologyReport RadiologyReport?

  @@unique([tenantId, orderNumber])
  @@index([encounterId])
  @@index([requestedById])
  @@index([cancelledById])
  @@index([tenantId, branchId, createdAt])
  @@index([tenantId, branchId, patientId])
  @@index([tenantId, branchId, status, requestedAt])
  @@index([tenantId, orderType, status])
  @@map("orders")
}

model OrderItem {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  orderId   String   @map("order_id") @db.Uuid
  itemType  String   @map("item_type") // SERVICE, INVENTORY
  itemId    String   @map("item_id") @db.Uuid
  name      String // Snapshot of item name at time of order
  quantity  Int
  unitPrice Decimal  @map("unit_price") @db.Decimal(12, 2)
  lineTotal Decimal  @map("line_total") @db.Decimal(12, 2)
  createdAt DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])
  order  Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([orderId])
  @@map("order_items")
}

model ClinicalOrderItem {
  id                  String   @id @default(uuid()) @db.Uuid
  tenantId            String   @map("tenant_id") @db.Uuid
  orderId             String   @map("order_id") @db.Uuid
  itemName            String   @map("item_name")
  labTestDefinitionId String?  @map("lab_test_definition_id") @db.Uuid
  notes               String?
  status              String   @default("PENDING")
  createdAt           DateTime @default(now()) @map("created_at")

  tenant            Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  order             Order              @relation(fields: [orderId], references: [id], onDelete: Cascade)
  labTestDefinition LabTestDefinition? @relation(fields: [labTestDefinitionId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([orderId])
  @@index([labTestDefinitionId])
  @@map("clinical_order_items")
}

model LabSpecimen {
  id              String    @id @default(uuid()) @db.Uuid
  tenantId        String    @map("tenant_id") @db.Uuid
  branchId        String    @map("branch_id") @db.Uuid
  patientId       String    @map("patient_id") @db.Uuid
  orderId         String    @unique @map("order_id") @db.Uuid
  specimenType    String    @map("specimen_type")
  accessionNumber String?   @map("accession_number")
  collectionMode  String    @default("ROUTINE") @map("collection_mode")
  collectedAt     DateTime? @map("collected_at")
  receivedAt      DateTime  @default(now()) @map("received_at")
  receivedById    String    @map("received_by_id") @db.Uuid
  status          String    @default("RECEIVED")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  branch  Branch  @relation(fields: [branchId], references: [id], onDelete: Restrict)
  patient Patient @relation(fields: [patientId], references: [id], onDelete: Restrict)
  order   Order   @relation(fields: [orderId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([branchId])
  @@index([orderId])
  @@index([tenantId, branchId])
  @@map("lab_specimens")
}

model ServiceCategory {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  name        String
  description String?
  createdBy   String   @map("created_by") @db.Uuid
  updatedBy   String   @map("updated_by") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant Tenant        @relation(fields: [tenantId], references: [id])
  items  ServiceItem[]

  @@index([tenantId])
  @@map("service_categories")
}

model ServiceItem {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  categoryId  String   @map("category_id") @db.Uuid
  code        String
  name        String
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  createdBy   String   @map("created_by") @db.Uuid
  updatedBy   String   @map("updated_by") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant              Tenant               @relation(fields: [tenantId], references: [id])
  category            ServiceCategory      @relation(fields: [categoryId], references: [id])
  prices              ServicePrice[]
  marketplaceListings MarketplaceListing[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([categoryId])
  @@map("service_items")
}

model ServicePrice {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  serviceItemId String   @map("service_item_id") @db.Uuid
  branchId      String   @map("branch_id") @db.Uuid
  amount        Decimal  @db.Decimal(12, 2)
  effectiveDate DateTime @default(now()) @map("effective_date")
  isActive      Boolean  @default(true) @map("is_active")
  createdBy     String   @map("created_by") @db.Uuid
  updatedBy     String   @map("updated_by") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  serviceItem ServiceItem @relation(fields: [serviceItemId], references: [id])
  branch      Branch      @relation(fields: [branchId], references: [id])

  @@index([tenantId])
  @@index([serviceItemId])
  @@index([branchId])
  @@map("service_prices")
}

model Invoice {
  id            String    @id @default(uuid()) @db.Uuid
  tenantId      String    @map("tenant_id") @db.Uuid
  orderId       String    @unique @map("order_id") @db.Uuid
  invoiceNumber String?   @map("invoice_number")
  totalAmount   Decimal   @map("total_amount") @db.Decimal(12, 2)
  paidAmount    Decimal   @default(0) @map("paid_amount") @db.Decimal(12, 2)
  status        String    @default("UNPAID")
  createdById   String?   @map("created_by_id") @db.Uuid
  updatedById   String?   @map("updated_by_id") @db.Uuid
  deletedAt     DateTime? @map("deleted_at")
  version       Int       @default(0)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  archivedAt    DateTime? @map("archived_at")
  archiveReason String?   @map("archive_reason")

  tenant          Tenant            @relation(fields: [tenantId], references: [id])
  order           Order             @relation(fields: [orderId], references: [id])
  payments        Payment[]
  reversals       PaymentReversal[]

  @@unique([tenantId, id])
  claims          Claim[]
  refunds         Refund[]
  insuranceClaims InsuranceClaim[]

  @@unique([tenantId, invoiceNumber])
  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@map("invoices")
}

model Payment {
  id               String    @id @default(uuid()) @db.Uuid
  tenantId         String    @map("tenant_id") @db.Uuid
  branchId         String    @map("branch_id") @db.Uuid
  invoiceId        String    @map("invoice_id") @db.Uuid
  cashierSessionId String    @map("cashier_session_id") @db.Uuid
  receiptNumber    String?   @map("receipt_number")
  amount           Decimal   @db.Decimal(12, 2)
  paymentMethod    String    @map("payment_method")
  status           String    @default("POSTED")
  gatewayReference String?   @map("gateway_reference")
  gatewayStatus    String?   @map("gateway_status")
  gatewayProvider  String?   @map("gateway_provider")
  idempotencyKey   String    @map("idempotency_key")
  createdById      String?   @map("created_by_id") @db.Uuid
  updatedById      String?   @map("updated_by_id") @db.Uuid
  deletedAt        DateTime? @map("deleted_at")
  version          Int       @default(0)
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  archivedAt       DateTime? @map("archived_at")
  archiveReason    String?   @map("archive_reason")

  tenant         Tenant            @relation(fields: [tenantId], references: [id])
  branch         Branch            @relation(fields: [branchId], references: [id])
  invoice        Invoice           @relation(fields: [invoiceId], references: [id])
  cashierSession CashierSession    @relation(fields: [tenantId, cashierSessionId, branchId], references: [tenantId, id, branchId])
  reversals      PaymentReversal[]
  void           PaymentVoid?
  refunds        Refund[]

  @@unique([tenantId, receiptNumber])
  @@unique([tenantId, id])
  @@unique([tenantId, id, branchId])
  @@index([tenantId, cashierSessionId, status])
  @@index([tenantId, createdAt])
  @@map("payments")
}

model IdempotencyRecord {
  id                 String   @id @default(uuid()) @db.Uuid
  tenantId           String   @map("tenant_id") @db.Uuid
  operation          String // BILLING_PAYMENT_POST
  key                String
  requestFingerprint String   @map("request_fingerprint") // Hash of normalized request
  status             String   @default("IN_PROGRESS") // IN_PROGRESS, COMPLETED, FAILED
  paymentId          String?  @map("payment_id") @db.Uuid // Set after successful payment creation
  responseData       Json?    @map("response_data") // Cached response for replay
  error              String?
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, operation, key])
  @@index([tenantId])
  @@index([status])
  @@map("idempotency_records")
}

model LabResult {
  id                       String    @id @default(uuid()) @db.Uuid
  tenantId                 String    @map("tenant_id") @db.Uuid
  orderId                  String    @unique @map("order_id") @db.Uuid
  status                   String    @default("PENDING_COLLECTION")
  results                  Json? // Key-value results snapshot
  remarks                  String? // Clinical remarks
  approvedById             String?   @map("approved_by_id") @db.Uuid
  lockedAt                 DateTime? @map("locked_at")
  encodedById              String?   @map("encoded_by_id") @db.Uuid
  encodedAt                DateTime? @map("encoded_at")
  validatedById            String?   @map("validated_by_id") @db.Uuid
  validatedAt              DateTime? @map("validated_at")
  releasedById             String?   @map("released_by_id") @db.Uuid
  releasedAt               DateTime? @map("released_at")
  lastEditedById           String?   @map("last_edited_by_id") @db.Uuid
  lastEditedAt             DateTime? @map("last_edited_at")
  createdById              String?   @map("created_by_id") @db.Uuid
  updatedById              String?   @map("updated_by_id") @db.Uuid
  deletedAt                DateTime? @map("deleted_at")
  version                  Int       @default(0)
  createdAt                DateTime  @default(now()) @map("created_at")
  updatedAt                DateTime  @updatedAt @map("updated_at")
  archivedAt               DateTime? @map("archived_at")
  archiveReason            String?   @map("archive_reason")
  // Critical result tracking fields
  isCritical               Boolean   @default(false) @map("is_critical")
  criticalStatus           String?   @map("critical_status") // OPEN, ACKNOWLEDGED, ESCALATED, RESOLVED
  criticalAcknowledgedAt   DateTime? @map("critical_acknowledged_at")
  criticalAcknowledgedById String?   @map("critical_acknowledged_by_id") @db.Uuid
  criticalEscalatedAt      DateTime? @map("critical_escalated_at")
  criticalEscalatedById    String?   @map("critical_escalated_by_id") @db.Uuid
  criticalEscalationNotes  String?   @map("critical_escalation_notes")
  criticalResolvedAt       DateTime? @map("critical_resolved_at")
  criticalResolvedById     String?   @map("critical_resolved_by_id") @db.Uuid
  criticalResolvedNotes    String?   @map("critical_resolved_notes")

  tenant    Tenant              @relation(fields: [tenantId], references: [id])
  order     Order               @relation(fields: [orderId], references: [id])
  versions  LabResultVersion[]
  signature LabResultSignature?

  @@index([tenantId, isCritical, criticalStatus])
  @@index([tenantId, status, archivedAt])
  @@map("lab_results")
}

model LabResultVersion {
  id          String   @id @default(uuid()) @db.Uuid
  labResultId String   @map("lab_result_id") @db.Uuid
  version     Int      @default(1)
  oldStatus   String   @map("old_status")
  newStatus   String   @map("new_status")
  amendedById String   @map("amended_by_id") @db.Uuid
  reason      String
  oldData     Json?    @map("old_data") // Stores the previous results snapshot
  createdAt   DateTime @default(now()) @map("created_at")

  labResult LabResult @relation(fields: [labResultId], references: [id])

  @@map("lab_result_versions")
}

model LabResultSignature {
  id            String    @id @default(uuid()) @db.Uuid
  labResultId   String    @unique @map("lab_result_id") @db.Uuid
  labResult     LabResult @relation(fields: [labResultId], references: [id])
  signedById    String    @map("signed_by_id") @db.Uuid
  signedAt      DateTime  @map("signed_at")
  signatureHash String    @map("signature_hash")

  @@map("lab_result_signatures")
}

model RadiologyReport {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  orderId        String   @unique @map("order_id") @db.Uuid
  interpretation String   @db.Text
  status         String   @default("FINALIZED")
  finalizedById  String   @map("finalized_by_id") @db.Uuid
  finalizedAt    DateTime @map("finalized_at")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])
  order  Order  @relation(fields: [orderId], references: [id])

  @@index([tenantId])
  @@index([tenantId, finalizedAt])
  @@map("radiology_reports")
}

model NotificationOutbox {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  recipientId String    @map("recipient_id") @db.Uuid
  type        String
  payload     String
  scheduledAt DateTime  @map("scheduled_at")
  sentAt      DateTime? @map("sent_at")
  status      String    @default("PENDING")

  tenant    Tenant  @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  recipient Patient @relation(fields: [tenantId, recipientId], references: [tenantId, id], onDelete: Restrict)

  @@index([tenantId])
  @@index([recipientId])
  @@index([status, scheduledAt])
  @@map("notification_outbox")
}

model AuditLog {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  branchId     String?  @map("branch_id") @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  eventKey     String   @map("event_key")
  recordType   String   @map("record_type")
  recordId     String   @map("record_id") @db.Uuid
  oldValues    Json?    @map("old_values")
  newValues    Json?    @map("new_values")
  createdAt    DateTime @default(now()) @map("created_at")
  ipAddress    String?  @map("ip_address")
  userAgent    String?  @map("user_agent")
  activeRole   String?  @map("active_role")
  sessionId    String?  @map("session_id") @db.Uuid
  hash         String?  @map("hash") @db.Char(64)
  previousHash String?  @map("previous_hash") @db.Char(64)
  signature    String?  @map("signature")

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@index([tenantId])
  @@index([branchId])
  @@index([createdAt])
  @@index([tenantId, createdAt])
  @@index([eventKey])
  @@index([recordType, recordId])
  @@index([userId, createdAt])
  @@index([tenantId, eventKey, createdAt])
  @@map("audit_logs")
}

// --- MODULE 4: INVENTORY & PHARMACY ---

model InventoryItem {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  name         String
  sku          String?
  category     String // DRUG, SUPPLY, EQUIPMENT
  unit         String // TABLET, BOX, PIECE
  reorderLevel Int      @default(10) @map("reorder_level")
  currentStock Int      @default(0) @map("current_stock")
  price        Decimal  @db.Decimal(12, 2)
  status       String   @default("ACTIVE") // ACTIVE, INACTIVE
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  stockLogs    StockLog[]
  branchStocks BranchStock[]

  @@unique([tenantId, sku])
  @@map("inventory_items")
}

model BranchStock {
  id              String   @id @default(uuid()) @db.Uuid
  tenantId        String   @map("tenant_id") @db.Uuid
  branchId        String   @map("branch_id") @db.Uuid
  inventoryItemId String   @map("inventory_item_id") @db.Uuid
  quantity        Int      @default(0)
  reorderLevel    Int      @default(10) @map("reorder_level")
  version         Int      @default(1)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  tenant        Tenant        @relation(fields: [tenantId], references: [id])
  branch        Branch        @relation(fields: [branchId], references: [id])
  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id])

  @@unique([tenantId, branchId, inventoryItemId])
  @@index([tenantId])
  @@index([branchId])
  @@index([inventoryItemId])
  @@index([tenantId, branchId])
  @@map("branch_stocks")
}

model StockLog {
  id              String   @id @default(uuid()) @db.Uuid
  tenantId        String   @map("tenant_id") @db.Uuid
  branchId        String   @map("branch_id") @db.Uuid
  inventoryItemId String   @map("inventory_item_id") @db.Uuid
  type            String // IN, OUT, ADJUSTMENT, RETURN
  quantity        Int
  previousStock   Int      @map("previous_stock")
  newStock        Int      @map("new_stock")
  referenceType   String?  @map("reference_type") // PURCHASE_ORDER, DISPENSING
  referenceId     String?  @map("reference_id") @db.Uuid
  remarks         String?
  createdAt       DateTime @default(now()) @map("created_at")

  tenant Tenant        @relation(fields: [tenantId], references: [id])
  branch Branch        @relation(fields: [branchId], references: [id])
  item   InventoryItem @relation(fields: [inventoryItemId], references: [id])

  @@map("stock_logs")
}

// --- MODULE 5: HUMAN RESOURCES & PAYROLL ---
// DEFERRED: HR & Payroll module not currently wired/supported. Do not implement.

model Department {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  name      String
  code      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  employees Employee[]

  @@unique([tenantId, code])
  @@map("departments")
}

model Employee {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String?  @map("user_id") @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  branchId       String   @map("branch_id") @db.Uuid
  employeeNumber String   @map("employee_number")
  department     String   @default("")
  position       String   @default("")
  hireDate       DateTime @default(now()) @map("hire_date")
  status         String   @default("ACTIVE") // ACTIVE/ON_LEAVE/SUSPENDED/RESIGNED/TERMINATED
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Existing/Legacy fields (kept for schema / existing service compatibility)
  firstName     String?     @map("first_name")
  lastName      String?     @map("last_name")
  jobTitle      String?     @map("job_title")
  joiningDate   DateTime?   @map("joining_date") @db.Date
  salary        Decimal?    @db.Decimal(12, 2)
  departmentId  String?     @map("department_id") @db.Uuid
  departmentRef Department? @relation(fields: [departmentId], references: [id])

  tenant           Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch           Branch           @relation(fields: [branchId], references: [id], onDelete: Cascade)
  user             User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  employeeBranches EmployeeBranch[]
  payslips         Payslip[]
  attendanceLogs   AttendanceLog[]
  leaveRequests    LeaveRequest[]
  licenses         LicenseRecord[]

  @@unique([tenantId, employeeNumber])
  @@map("employees")
}

model EmployeeBranch {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  employeeId String   @map("employee_id") @db.Uuid
  branchId   String   @map("branch_id") @db.Uuid
  isPrimary  Boolean  @default(false) @map("is_primary")
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  branch   Branch   @relation(fields: [branchId], references: [id], onDelete: Restrict)

  @@unique([tenantId, employeeId, branchId])
  @@index([tenantId])
  @@index([employeeId])
  @@index([branchId])
  @@index([tenantId, branchId])
  @@index([tenantId, employeeId])
  @@map("employee_branches")
}

model Payslip {
  id              String   @id @default(uuid()) @db.Uuid
  tenantId        String   @map("tenant_id") @db.Uuid
  branchId        String   @map("branch_id") @db.Uuid
  employeeId      String   @map("employee_id") @db.Uuid
  periodStart     DateTime @map("period_start") @db.Date
  periodEnd       DateTime @map("period_end") @db.Date
  basicSalary     Decimal  @map("basic_salary") @db.Decimal(12, 2)
  totalAllowances Decimal  @map("total_allowances") @db.Decimal(12, 2)
  totalDeductions Decimal  @map("total_deductions") @db.Decimal(12, 2)
  netSalary       Decimal  @map("net_salary") @db.Decimal(12, 2)
  status          String   @default("DRAFT") // DRAFT, PAID
  createdAt       DateTime @default(now()) @map("created_at")

  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  branch   Branch   @relation(fields: [branchId], references: [id])
  employee Employee @relation(fields: [employeeId], references: [id])

  @@unique([tenantId, employeeId, periodStart, periodEnd])
  @@index([tenantId, branchId])
  @@index([tenantId, employeeId, branchId])
  @@map("payslips")
}

// --- MODULE 10: QUEUEING & PATIENT FLOW ---

model QueueEntry {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  branchId      String   @map("branch_id") @db.Uuid
  patientId     String?  @map("patient_id") @db.Uuid
  patientName   String?  @map("patient_name")
  queueNumber   String   @map("queue_number")
  category      String   @default("REGULAR") // REGULAR, PRIORITY, EMERGENCY
  serviceType   String   @map("service_type") // RECEPTION, CASHIER, LABORATORY, DOCTOR
  status        String   @default("WAITING") // WAITING, CALLING, SERVING, COMPLETED, CANCELLED
  counterNumber String?  @map("counter_number")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, branchId, status, createdAt])
  @@index([tenantId, status, createdAt])
  @@map("queue_entries")
}

// --- MODULE 11: HMO & PHILHEALTH CLAIMS ---

model HmoPartner {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  name          String
  code          String
  contactPerson String?  @map("contact_person")
  email         String?
  status        String   @default("ACTIVE")
  createdAt     DateTime @default(now()) @map("created_at")

  tenant Tenant  @relation(fields: [tenantId], references: [id])
  claims Claim[]

  @@unique([tenantId, code])
  @@map("hmo_partners")
}

model Claim {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  hmoPartnerId   String   @map("hmo_partner_id") @db.Uuid
  invoiceId      String   @map("invoice_id") @db.Uuid
  claimNumber    String   @map("claim_number")
  loaNumber      String?  @map("loa_number")
  amountClaimed  Decimal  @map("amount_claimed") @db.Decimal(12, 2)
  amountApproved Decimal? @map("amount_approved") @db.Decimal(12, 2)
  status         String   @default("PENDING") // PENDING, SUBMITTED, APPROVED, DENIED, PAID
  remarks        String?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  tenant     Tenant     @relation(fields: [tenantId], references: [id])
  hmoPartner HmoPartner @relation(fields: [hmoPartnerId], references: [id])
  invoice    Invoice    @relation(fields: [invoiceId], references: [id])

  @@unique([tenantId, claimNumber])
  @@map("claims")
}

// --- MODULE: FOUNDATION & SECURITY ---

model PaymentReversal {
  id                String    @id @default(uuid()) @db.Uuid
  tenantId          String    @map("tenant_id") @db.Uuid
  branchId          String    @map("branch_id") @db.Uuid
  paymentId         String    @map("payment_id") @db.Uuid
  invoiceId         String    @map("invoice_id") @db.Uuid
  approvalRequestId String    @unique @map("approval_request_id") @db.Uuid
  amount            Decimal   @db.Decimal(12, 2)
  type              String // REFUND, PAYMENT_VOID
  status            String    @default("PENDING") // PENDING, APPLIED, REJECTED, CANCELLED
  reason            String
  requestedBy       String    @map("requested_by") @db.Uuid
  approvedBy        String?   @map("approved_by") @db.Uuid
  appliedBy         String?   @map("applied_by") @db.Uuid
  requestedAt       DateTime  @default(now()) @map("requested_at")
  approvedAt        DateTime? @map("approved_at")
  appliedAt         DateTime? @map("applied_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  payment         Payment         @relation(fields: [paymentId], references: [id])
  invoice         Invoice         @relation(fields: [invoiceId], references: [id])
  approvalRequest ApprovalRequest @relation(fields: [approvalRequestId], references: [id])

  @@index([tenantId])
  @@index([branchId])
  @@index([paymentId])
  @@index([invoiceId])
  @@index([status])
  @@index([type])
  @@map("payment_reversals")
}

model Permission {
  id        String  @id @default(uuid()) @db.Uuid
  tenantId  String  @map("tenant_id") @db.Uuid
  name      String // e.g. patient.view, billing.refund.approve
  scope     String? // e.g. branch, department, tenant
  riskLevel String  @default("PRIVILEGED") @map("risk_level")

  tenant          Tenant           @relation(fields: [tenantId], references: [id])
  rolePermissions RolePermission[]

  @@unique([tenantId, name])
  @@map("permissions")
}

