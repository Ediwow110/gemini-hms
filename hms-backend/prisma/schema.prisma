// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  branches           Branch[]
  users              User[]
  patients           Patient[]
  roles              Role[]
  permissions        Permission[]
  approvalRequests   ApprovalRequest[]
  notifications      Notification[]
  files              File[]
  cashierSessions    CashierSession[]
  numberingSequences NumberingSequence[]
  serviceCatalog     ServiceCatalog[]
  orders             Order[]
  orderItems         OrderItem[]
  invoices           Invoice[]
  payments           Payment[]
  labResults         LabResult[]
  auditLogs          AuditLog[]
  inventoryItems     InventoryItem[]
  stockBatches       StockBatch[]
  stockMovements     StockMovement[]
  departments        Department[]
  employees          Employee[]
  attendanceLogs     AttendanceLog[]
  leaveRequests      LeaveRequest[]
  employeeBranches   EmployeeBranch[]
  payslips           Payslip[]
  queueEntries       QueueEntry[]
  hmoPartners        HmoPartner[]
  claims             Claim[]
  userBranches       UserBranch[]
  reportExports       ReportExport[]
  reportExportLogs    ReportExportLog[]
  patientMergeRequests PatientMergeRequest[]
  idempotencyRecords IdempotencyRecord[]
  encounters         Encounter[]
  notificationLogs   NotificationLog[]
  portalOtps         PortalOtp[]
  appointments       Appointment[]
  doctorSchedules    DoctorSchedule[]
  queueTickets       QueueTicket[]
  medications        Medication[]
  prescriptions      Prescription[]
  prescriptionItems  PrescriptionItem[]
  dispenseLogs       DispenseLog[]
  radiologyOrders    RadiologyOrder[]
  radiologyReports   RadiologyReport[]

  @@map("tenants")
}

model Branch {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  name      String
  code      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant           Tenant           @relation(fields: [tenantId], references: [id])
  orders           Order[]
  userBranches     UserBranch[]
  inventoryItems   InventoryItem[]
  stockBatches     StockBatch[]
  stockMovements   StockMovement[]
  departments      Department[]
  employees        Employee[]
  attendanceLogs   AttendanceLog[]
  leaveRequests    LeaveRequest[]
  employeeBranches EmployeeBranch[]
  payslips         Payslip[]
  encounters       Encounter[]
  notificationLogs NotificationLog[]
  portalOtps       PortalOtp[]
  appointments     Appointment[]
  doctorSchedules  DoctorSchedule[]
  queueTickets     QueueTicket[]
  medications      Medication[]
  prescriptions    Prescription[]
  radiologyOrders  RadiologyOrder[]
  radiologyReports RadiologyReport[]

  @@map("branches")
}

model User {
  id                String    @id @default(uuid()) @db.Uuid
  tenantId          String    @map("tenant_id") @db.Uuid
  email             String
  passwordHash      String    @map("password_hash")
  isMfaEnabled      Boolean   @default(false) @map("is_mfa_enabled")
  status            String    @default("ACTIVE")
  isActive          Boolean   @default(true) @map("is_active")
  deactivatedAt     DateTime? @map("deactivated_at")
  deactivatedReason String?   @map("deactivated_reason")
  tokenVersion      Int       @default(0) @map("token_version")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  tenant             Tenant            @relation(fields: [tenantId], references: [id])
  auditLogs          AuditLog[]
  userRoles          UserRole[]
  userBranches       UserBranch[]
  employee           Employee?
  reportExports      ReportExport[]    @relation("RequestedExports")
  decidedExports     ReportExport[]    @relation("DecidedExports")
  requestedApprovals ApprovalRequest[] @relation("RequestedApprovals")
  approvedApprovals  ApprovalRequest[] @relation("ApprovedApprovals")
  reportExportLogs   ReportExportLog[]
  mergeRequested     PatientMergeRequest[] @relation("MergeRequested")
  mergeApproved      PatientMergeRequest[] @relation("MergeApproved")
  doctorAppointments Appointment[]     @relation("DoctorAppointments")
  doctorSchedules    DoctorSchedule[]  @relation("DoctorSchedules")
  prescriptions      Prescription[]    @relation("PrescribingDoctor")
  dispenseLogs       DispenseLog[]     @relation("DispensingPharmacist")
  radiologyOrders    RadiologyOrder[]  @relation("OrderingDoctor")
  radiologyReports   RadiologyReport[] @relation("Radiologist")

  @@unique([tenantId, email])
  @@map("users")
}

model Role {
  id             String    @id @default(uuid()) @db.Uuid
  tenantId       String    @map("tenant_id") @db.Uuid
  name           String
  status         String    @default("ACTIVE")
  isSystem       Boolean   @default(false) @map("is_system")
  archivedAt     DateTime? @map("archived_at")
  archivedReason String?   @map("archived_reason")

  tenant          Tenant           @relation(fields: [tenantId], references: [id])
  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@map("roles")
}

model UserRole {
  userId        String    @map("user_id") @db.Uuid
  roleId        String    @map("role_id") @db.Uuid
  status        String    @default("ACTIVE")
  revokedAt     DateTime? @map("revoked_at")
  revokedReason String?   @map("revoked_reason")

  user User @relation(fields: [userId], references: [id])
  role Role @relation(fields: [roleId], references: [id])

  @@id([userId, roleId])
  @@map("user_roles")
}

model UserBranch {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  branchId  String   @map("branch_id") @db.Uuid
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId, branchId])
  @@index([tenantId])
  @@index([userId])
  @@index([branchId])
  @@index([tenantId, userId])
  @@index([tenantId, branchId])
  @@map("user_branches")
}

enum EncounterStatus {
  PLANNED
  ARRIVED
  IN_PROGRESS
  FINISHED
  CANCELLED
  ENTERED_IN_ERROR
  UNKNOWN
}

model Encounter {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  branchId  String   @map("branch_id") @db.Uuid
  patientId String   @map("patient_id") @db.Uuid
  
  status    EncounterStatus @default(IN_PROGRESS)
  type      String?  // OUTPATIENT, INPATIENT, EMERGENCY, etc.
  
  startedAt DateTime @default(now()) @map("started_at")
  endedAt   DateTime? @map("ended_at")
  
  reason    String?
  notes     String?
  
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch    Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  patient   Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  prescriptions Prescription[]
  radiologyOrders RadiologyOrder[]

  @@index([tenantId])
  @@index([branchId])
  @@index([patientId])
  @@index([status])
  @@map("encounters")
}

model Patient {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  patientNumber String   @map("patient_number")
  firstName     String   @map("first_name")
  lastName      String   @map("last_name")
  dob           DateTime @db.Date
  status        String   @default("ACTIVE")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  tenant           Tenant            @relation(fields: [tenantId], references: [id])
  orders           Order[]
  encounters       Encounter[]
  notificationLogs NotificationLog[]
  portalOtps       PortalOtp[]
  appointments     Appointment[]
  queueTickets     QueueTicket[]
  prescriptions    Prescription[]
  radiologyOrders  RadiologyOrder[]

  @@unique([tenantId, patientNumber])
  @@map("patients")
}

model Order {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  branchId    String   @map("branch_id") @db.Uuid
  patientId   String   @map("patient_id") @db.Uuid
  orderNumber String   @map("order_number")
  status      String   @default("DRAFT")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant     Tenant      @relation(fields: [tenantId], references: [id])
  branch     Branch      @relation(fields: [branchId], references: [id])
  patient    Patient     @relation(fields: [patientId], references: [id])
  items      OrderItem[]
  invoice    Invoice?
  labResult  LabResult?

  @@unique([tenantId, orderNumber])
  @@map("orders")
}

model OrderItem {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  orderId   String   @map("order_id") @db.Uuid
  itemType  String   @map("item_type") // SERVICE, INVENTORY
  itemId    String   @map("item_id") @db.Uuid
  name      String // Snapshot of item name at time of order
  quantity  Int
  unitPrice Decimal  @map("unit_price") @db.Decimal(12, 2)
  lineTotal Decimal  @map("line_total") @db.Decimal(12, 2)
  createdAt DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])
  order  Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([orderId])
  @@map("order_items")
}

model ServiceCatalog {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  name      String
  code      String
  category  String // CONSULTATION, LAB_TEST, RADIOLOGY, etc.
  price     Decimal  @db.Decimal(12, 2)
  status    String   @default("ACTIVE") // ACTIVE, ARCHIVED
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, code])
  @@map("service_catalog")
}

model Invoice {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  orderId       String   @unique @map("order_id") @db.Uuid
  invoiceNumber String?  @map("invoice_number")
  totalAmount   Decimal  @map("total_amount") @db.Decimal(12, 2)
  paidAmount    Decimal  @default(0) @map("paid_amount") @db.Decimal(12, 2)
  status        String   @default("UNPAID")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  tenant    Tenant            @relation(fields: [tenantId], references: [id])
  order     Order             @relation(fields: [orderId], references: [id])
  payments  Payment[]
  reversals PaymentReversal[]
  claims    Claim[]

  @@unique([tenantId, invoiceNumber])
  @@map("invoices")
}

model Payment {
  id               String   @id @default(uuid()) @db.Uuid
  tenantId         String   @map("tenant_id") @db.Uuid
  invoiceId        String   @map("invoice_id") @db.Uuid
  cashierSessionId String   @map("cashier_session_id") @db.Uuid
  receiptNumber    String?  @map("receipt_number")
  amount           Decimal  @db.Decimal(12, 2)
  paymentMethod    String   @map("payment_method")
  status           String   @default("POSTED")
  idempotencyKey   String   @map("idempotency_key")
  createdAt        DateTime @default(now()) @map("created_at")

  tenant         Tenant            @relation(fields: [tenantId], references: [id])
  invoice        Invoice           @relation(fields: [invoiceId], references: [id])
  cashierSession CashierSession    @relation(fields: [cashierSessionId], references: [id])
  reversals      PaymentReversal[]

  @@unique([tenantId, receiptNumber])
  @@map("payments")
}

model IdempotencyRecord {
  id                String   @id @default(uuid()) @db.Uuid
  tenantId          String   @map("tenant_id") @db.Uuid
  operation         String // BILLING_PAYMENT_POST
  key               String
  requestFingerprint String  @map("request_fingerprint") // Hash of normalized request
  status            String   @default("IN_PROGRESS") // IN_PROGRESS, COMPLETED, FAILED
  paymentId         String?  @map("payment_id") @db.Uuid // Set after successful payment creation
  responseData      Json?    @map("response_data") // Cached response for replay
  error             String?
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, operation, key])
  @@index([tenantId])
  @@index([status])
  @@map("idempotency_records")
}

model LabResult {
  id           String    @id @default(uuid()) @db.Uuid
  tenantId     String    @map("tenant_id") @db.Uuid
  orderId      String    @unique @map("order_id") @db.Uuid
  status       String    @default("PENDING_COLLECTION")
  results      Json? // Key-value results snapshot
  remarks      String? // Clinical remarks
  approvedById String?   @map("approved_by_id") @db.Uuid
  lockedAt     DateTime? @map("locked_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  tenant   Tenant             @relation(fields: [tenantId], references: [id])
  order    Order              @relation(fields: [orderId], references: [id])
  versions LabResultVersion[]

  @@map("lab_results")
}

model LabResultVersion {
  id          String   @id @default(uuid()) @db.Uuid
  labResultId String   @map("lab_result_id") @db.Uuid
  version     Int      @default(1)
  oldStatus   String   @map("old_status")
  newStatus   String   @map("new_status")
  amendedById String   @map("amended_by_id") @db.Uuid
  reason      String
  oldData     Json?    @map("old_data") // Stores the previous results snapshot
  createdAt   DateTime @default(now()) @map("created_at")

  labResult LabResult @relation(fields: [labResultId], references: [id])

  @@map("lab_result_versions")
}

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  branchId   String?  @map("branch_id") @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  eventKey   String   @map("event_key")
  recordType String   @map("record_type")
  recordId   String   @map("record_id") @db.Uuid
  oldValues  Json?    @map("old_values")
  newValues  Json?    @map("new_values")
  createdAt  DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@index([tenantId])
  @@index([branchId])
  @@map("audit_logs")
}

// --- MODULE 4: INVENTORY & PHARMACY ---

enum StockMovementType {
  RECEIVE
  ISSUE
  ADJUSTMENT
  TRANSFER
}

model InventoryItem {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  branchId      String   @map("branch_id") @db.Uuid
  name          String
  sku           String   @map("sku")
  unitOfMeasure String   @map("unit_of_measure")
  reorderLevel  Int      @default(0) @map("reorder_level")
  totalQuantity Int      @default(0) @map("total_quantity")
  price         Decimal  @db.Decimal(12, 2)
  status        String   @default("ACTIVE") // ACTIVE, INACTIVE
  
  createdBy     String   @map("created_by") @db.Uuid
  updatedBy     String   @map("updated_by") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  tenant         Tenant          @relation(fields: [tenantId], references: [id])
  branch         Branch          @relation(fields: [branchId], references: [id])
  batches        StockBatch[]
  movements      StockMovement[]
  medications    Medication[]

  @@unique([tenantId, sku])
  @@index([tenantId])
  @@index([branchId])
  @@map("inventory_items")
}

model StockBatch {
  id              String    @id @default(uuid()) @db.Uuid
  tenantId        String    @map("tenant_id") @db.Uuid
  branchId        String    @map("branch_id") @db.Uuid
  inventoryItemId String    @map("inventory_item_id") @db.Uuid
  batchNumber     String    @map("batch_number")
  expiryDate      DateTime? @map("expiry_date")
  quantity        Int       @default(0)

  createdBy      String   @map("created_by") @db.Uuid
  updatedBy      String   @map("updated_by") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  tenant        Tenant        @relation(fields: [tenantId], references: [id])
  branch        Branch        @relation(fields: [branchId], references: [id])
  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id])
  movements     StockMovement[]

  @@index([tenantId])
  @@index([branchId])
  @@index([inventoryItemId])
  @@map("stock_batches")
}

model StockMovement {
  id              String            @id @default(uuid()) @db.Uuid
  tenantId        String            @map("tenant_id") @db.Uuid
  branchId        String            @map("branch_id") @db.Uuid
  inventoryItemId String            @map("inventory_item_id") @db.Uuid
  stockBatchId    String?           @map("stock_batch_id") @db.Uuid
  movementType    StockMovementType @map("movement_type")
  quantityChange  Int               @map("quantity_change")
  referenceId     String?           @map("reference_id")
  reason          String

  createdBy      String   @map("created_by") @db.Uuid
  updatedBy      String   @map("updated_by") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  tenant        Tenant        @relation(fields: [tenantId], references: [id])
  branch        Branch        @relation(fields: [branchId], references: [id])
  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id])
  stockBatch    StockBatch?   @relation(fields: [stockBatchId], references: [id])

  @@index([tenantId])
  @@index([branchId])
  @@index([inventoryItemId])
  @@index([stockBatchId])
  @@map("stock_movements")
}

// --- MODULE 5: HUMAN RESOURCES & PAYROLL ---

enum EmployeeStatus {
  ACTIVE
  ON_LEAVE
  SUSPENDED
  TERMINATED
}

model Department {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  branchId  String   @map("branch_id") @db.Uuid
  name      String
  code      String
  
  createdBy String   @map("created_by") @db.Uuid
  updatedBy String   @map("updated_by") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  branch    Branch     @relation(fields: [branchId], references: [id])
  employees Employee[]
  appointments    Appointment[]
  doctorSchedules DoctorSchedule[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([branchId])
  @@map("departments")
}

model Employee {
  id               String         @id @default(uuid()) @db.Uuid
  tenantId         String         @map("tenant_id") @db.Uuid
  branchId         String         @map("branch_id") @db.Uuid
  userId           String?        @unique @map("user_id") @db.Uuid
  departmentId     String?        @map("department_id") @db.Uuid
  employeeIdNumber String         @map("employee_id_number")
  firstName        String         @map("first_name")
  lastName         String         @map("last_name")
  jobTitle         String         @map("job_title")
  status           EmployeeStatus @default(ACTIVE)
  hireDate         DateTime       @map("hire_date")
  terminationDate  DateTime?      @map("termination_date")
  salary           Decimal        @db.Decimal(12, 2)
  
  createdBy        String         @map("created_by") @db.Uuid
  updatedBy        String         @map("updated_by") @db.Uuid
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  tenant           Tenant           @relation(fields: [tenantId], references: [id])
  branch           Branch           @relation(fields: [branchId], references: [id])
  user             User?            @relation(fields: [userId], references: [id])
  department       Department?      @relation(fields: [departmentId], references: [id])
  attendanceLogs   AttendanceLog[]
  leaveRequests    LeaveRequest[]
  employeeBranches EmployeeBranch[]
  payslips         Payslip[]

  @@unique([tenantId, employeeIdNumber])
  @@index([tenantId])
  @@index([branchId])
  @@map("employees")
}

model AttendanceLog {
  id         String    @id @default(uuid()) @db.Uuid
  tenantId   String    @map("tenant_id") @db.Uuid
  branchId   String    @map("branch_id") @db.Uuid
  employeeId String    @map("employee_id") @db.Uuid
  date       DateTime  @db.Date
  clockIn    DateTime  @map("clock_in")
  clockOut   DateTime? @map("clock_out")
  
  createdBy  String    @map("created_by") @db.Uuid
  updatedBy  String    @map("updated_by") @db.Uuid
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  branch   Branch   @relation(fields: [branchId], references: [id])
  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([tenantId])
  @@index([branchId])
  @@index([employeeId])
  @@map("attendance_logs")
}

model LeaveRequest {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  branchId   String   @map("branch_id") @db.Uuid
  employeeId String   @map("employee_id") @db.Uuid
  type       String   // e.g. SICK, VACATION
  startDate  DateTime @map("start_date")
  endDate    DateTime @map("end_date")
  status     String   @default("PENDING") // PENDING, APPROVED, REJECTED
  
  createdBy  String   @map("created_by") @db.Uuid
  updatedBy  String   @map("updated_by") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  branch   Branch   @relation(fields: [branchId], references: [id])
  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([tenantId])
  @@index([branchId])
  @@index([employeeId])
  @@map("leave_requests")
}

model EmployeeBranch {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  employeeId String   @map("employee_id") @db.Uuid
  branchId   String   @map("branch_id") @db.Uuid
  isPrimary  Boolean  @default(false) @map("is_primary")
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  branch   Branch   @relation(fields: [branchId], references: [id], onDelete: Restrict)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([tenantId, employeeId, branchId])
  @@index([tenantId])
  @@index([employeeId])
  @@index([branchId])
  @@index([tenantId, branchId])
  @@index([tenantId, employeeId])
  @@map("employee_branches")
}

model Payslip {
