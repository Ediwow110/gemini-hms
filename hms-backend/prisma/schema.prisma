  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  code        String
  description String
  category    String
  fees        Decimal  @db.Decimal(10, 2)
  status      String   @default("ACTIVE")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, code])
  @@map("cpt_codes")
}

model LabTestDefinition {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  code        String   @map("code")
  name        String   @map("name")
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant             Tenant                       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parameters         LabTestParameterDefinition[]
  clinicalOrderItems ClinicalOrderItem[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("lab_test_definitions")
}

model LabTestParameterDefinition {
  id                 String   @id @default(uuid()) @db.Uuid
  tenantId           String   @map("tenant_id") @db.Uuid
  testDefinitionId   String   @map("test_definition_id") @db.Uuid
  parameterName      String   @map("parameter_name")
  code               String   @map("code")
  unit               String?
  referenceRangeText String?  @map("reference_range_text")
  minNormal          Float?   @map("min_normal")
  maxNormal          Float?   @map("max_normal")
  minCritical        Float?   @map("min_critical")
  maxCritical        Float?   @map("max_critical")
  valueType          String   @default("NUMERIC") @map("value_type")
  allowedValues      String?  @map("allowed_values")
  isRequired         Boolean  @default(true) @map("is_required")
  displayOrder       Int      @default(0) @map("display_order")
  isActive           Boolean  @default(true) @map("is_active")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  tenant         Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  testDefinition LabTestDefinition @relation(fields: [testDefinitionId], references: [id], onDelete: Cascade)

  @@unique([tenantId, testDefinitionId, code])
  @@index([tenantId])
  @@index([testDefinitionId])
  @@map("lab_test_parameter_definitions")
}

enum RFQStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
}

enum OrderStatus {
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  COMPLETED
  CANCELLED
}

enum AssetInstallStatus {
  PENDING_ASSESSMENT
  SITE_READY
  ASSEMBLING
  INSTALLED
  COMMISSIONED
  HANDED_OVER
}

enum InstallStatus {
  ASSIGNED
  IN_PROGRESS
  COMMISSIONED
  COMPLETED
  FAILED
}

enum ShipmentStatus {
  PENDING
  PROCESSING
  SHIPPED
  IN_TRANSIT
  DELIVERED
  CANCELLED
}

enum DeliveryJobStatus {
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  FAILED
}

model RFQ {
  id        String    @id @default(uuid()) @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  branchId  String    @map("branch_id") @db.Uuid
  title     String
  status    RFQStatus @default(DRAFT)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  quotes Quote[]
  tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch Branch  @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@index([tenantId, branchId])
  @@index([status])
  @@map("rfqs")
}

model Quote {
  id          String      @id @default(uuid()) @db.Uuid
  rfqId       String      @map("rfq_id") @db.Uuid
  tenantId    String      @map("tenant_id") @db.Uuid
  supplierId  String?     @map("supplier_id") @db.Uuid
  status      QuoteStatus @default(DRAFT)
  totalAmount Decimal     @map("total_amount") @db.Decimal(12, 2)
  createdAt   DateTime    @default(now()) @map("created_at")
  convertedAt DateTime?   @map("converted_at")
  approvedAt  DateTime?   @map("approved_at")

  rfq         RFQ          @relation(fields: [rfqId], references: [id], onDelete: Cascade)
  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supplier    Supplier?    @relation(fields: [supplierId], references: [id])
  salesOrders SalesOrder[]

  @@index([rfqId])
  @@index([tenantId, status])
  @@map("quotes")
}

model SalesOrder {
  id        String      @id @default(uuid()) @db.Uuid
  quoteId   String      @map("quote_id") @db.Uuid
  tenantId  String      @map("tenant_id") @db.Uuid
  status    OrderStatus @default(CONFIRMED)
  createdAt DateTime    @default(now()) @map("created_at")

  quote     Quote      @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assets    Asset[]
  shipments Shipment[]

  @@index([quoteId])
  @@index([tenantId])
  @@map("sales_orders")
}

model Shipment {
  id             String         @id @default(uuid()) @db.Uuid
  tenantId       String         @map("tenant_id") @db.Uuid
  salesOrderId   String         @map("sales_order_id") @db.Uuid
  trackingNumber String?        @unique @map("tracking_number")
  status         ShipmentStatus @default(PENDING)
  carrier        String?
  shippedAt      DateTime?      @map("shipped_at")
  deliveredAt    DateTime?      @map("delivered_at")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  salesOrder   SalesOrder    @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
  deliveryJobs DeliveryJob[]

  @@index([tenantId])
  @@index([salesOrderId])
  @@map("shipments")
}

model DeliveryJob {
  id             String            @id @default(uuid()) @db.Uuid
  tenantId       String            @map("tenant_id") @db.Uuid
  shipmentId     String            @map("shipment_id") @db.Uuid
  assignedUserId String            @map("assigned_user_id") @db.Uuid
  status         DeliveryJobStatus @default(ASSIGNED)
  startedAt      DateTime?         @map("started_at")
  completedAt    DateTime?         @map("completed_at")
  notes          String?

  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  shipment     Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  assignedUser User     @relation(fields: [assignedUserId], references: [id])

  @@index([tenantId])
  @@index([shipmentId])
  @@index([assignedUserId])
  @@map("delivery_jobs")
}

model Asset {
  id                 String             @id @default(uuid()) @db.Uuid
  salesOrderId       String             @map("sales_order_id") @db.Uuid
  tenantId           String             @map("tenant_id") @db.Uuid
  serialNumber       String             @unique @map("serial_number")
  model              String
  warrantyStart      DateTime?          @map("warranty_start")
  warrantyEnd        DateTime?          @map("warranty_end")
  installationStatus AssetInstallStatus @default(PENDING_ASSESSMENT) @map("installation_status")

  salesOrder       SalesOrder        @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  installationJobs InstallationJob[]

  @@index([salesOrderId])
  @@index([tenantId])
  @@map("assets")
}

model InstallationJob {
  id               String        @id @default(uuid()) @db.Uuid
  tenantId         String        @map("tenant_id") @db.Uuid
  assetId          String        @map("asset_id") @db.Uuid
  assignedUserId   String        @map("assigned_user_id") @db.Uuid
  status           InstallStatus @default(ASSIGNED)
  notes            String?       @db.Text
  commissionedAt   DateTime?     @map("commissioned_at")
  handoverSignedAt DateTime?     @map("handover_signed_at")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  tenant       Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  asset        Asset  @relation(fields: [assetId], references: [id], onDelete: Cascade)
  assignedUser User   @relation(fields: [assignedUserId], references: [id])

  @@index([assetId])
  @@index([tenantId])
  @@index([assignedUserId])
  @@map("installation_jobs")
}

enum ListingStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  SUSPENDED
}

// --- MODULE 5(e): IT SUPPORT ---

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_USER
  RESOLVED
  CLOSED
}

enum TicketIssueType {
  LOGIN_FAILURE
  PASSWORD_RESET
  MFA_RESET
  ACCOUNT_UNLOCK
  PERMISSION_REQUEST
  SESSION_LOCKOUT
  SYSTEM_BUG
  OTHER
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model SupportTicket {
  id           String          @id @default(uuid()) @db.Uuid
  tenantId     String          @map("tenant_id") @db.Uuid
  branchId     String?         @map("branch_id") @db.Uuid
  reportedById String          @map("reported_by_id") @db.Uuid
  assignedToId String?         @map("assigned_to_id") @db.Uuid
  issueType    TicketIssueType @map("issue_type")
  summary      String
  description  String?         @db.Text
  status       TicketStatus    @default(OPEN)
  priority     TicketPriority  @default(MEDIUM)
  resolution   String?         @db.Text
  resolvedAt   DateTime?       @map("resolved_at")
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")

  tenant     Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch     Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)
  reportedBy User    @relation("TicketReporter", fields: [reportedById], references: [id])
  assignedTo User?   @relation("TicketAssignee", fields: [assignedToId], references: [id])

  @@index([tenantId])
  @@index([branchId])
  @@index([status])
  @@index([assignedToId])
  @@map("support_tickets")
}

model MarketplaceListing {
  id            String        @id @default(uuid()) @db.Uuid
  tenantId      String        @map("tenant_id") @db.Uuid
  serviceItemId String        @map("service_item_id") @db.Uuid
  supplierId    String?       @map("supplier_id") @db.Uuid
  status        ListingStatus @default(PENDING_APPROVAL)

  // Overrides or additional info for marketplace
  description   String?  @db.Text
  priceOverride Decimal? @map("price_override") @db.Decimal(12, 2)

  // Metadata for moderation
  rejectionReason String?   @map("rejection_reason")
  approvedAt      DateTime? @map("approved_at")
  approvedById    String?   @map("approved_by_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  serviceItem ServiceItem @relation(fields: [serviceItemId], references: [id], onDelete: Cascade)
  supplier    Supplier?   @relation(fields: [supplierId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([status])
  @@map("marketplace_listings")
}

model NurseTask {
  id             String  @id @default(uuid()) @db.Uuid
  tenantId       String  @map("tenant_id") @db.Uuid
  branchId       String  @map("branch_id") @db.Uuid
  patientId      String? @map("patient_id") @db.Uuid
  assignedUserId String? @map("assigned_user_id") @db.Uuid
  createdById    String  @map("created_by_id") @db.Uuid

  title       String       @db.VarChar(200)
  description String?      @db.Text
  priority    TaskPriority @default(MEDIUM)
  status      TaskStatus   @default(OPEN)

  dueAt              DateTime? @map("due_at")
  completedAt        DateTime? @map("completed_at")
  completedById      String?   @map("completed_by_id") @db.Uuid
  cancelledAt        DateTime? @map("cancelled_at")
  cancelledById      String?   @map("cancelled_by_id") @db.Uuid
  cancellationReason String?   @map("cancellation_reason") @db.VarChar(500)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch      Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  patient     Patient? @relation(fields: [patientId], references: [id], onDelete: SetNull)
  assignedTo  User?    @relation("NurseTaskAssigned", fields: [assignedUserId], references: [id], onDelete: SetNull)
  createdBy   User     @relation("NurseTaskCreated", fields: [createdById], references: [id])
  completedBy User?    @relation("NurseTaskCompleted", fields: [completedById], references: [id], onDelete: SetNull)
  cancelledBy User?    @relation("NurseTaskCancelled", fields: [cancelledById], references: [id], onDelete: SetNull)

  @@index([tenantId, branchId, status])
  @@index([tenantId, assignedUserId, status])
  @@index([tenantId, patientId])
  @@index([dueAt])
  @@map("nurse_tasks")
}

model RefillRequest {
  id              String              @id @default(uuid()) @db.Uuid
  tenantId        String              @map("tenant_id") @db.Uuid
  patientId       String              @map("patient_id") @db.Uuid
  prescriptionId  String              @map("prescription_id") @db.Uuid
  status          RefillRequestStatus @default(PENDING)
  reason          String?             @db.VarChar(500)
  reviewedById    String?             @map("reviewed_by_id") @db.Uuid
  reviewedAt      DateTime?           @map("reviewed_at")
  reviewNotes     String?             @map("review_notes") @db.VarChar(500)
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  patient      Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)
  prescription Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)
  reviewedBy   User?        @relation("RefillReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([tenantId, patientId])
  @@index([tenantId, status])
  @@map("refill_requests")
}

enum RefillRequestStatus {
  PENDING
  APPROVED
  DENIED
}

model MedicalRecordRequest {
  id              String                     @id @default(uuid()) @db.Uuid
  tenantId        String                     @map("tenant_id") @db.Uuid
  patientId       String                     @map("patient_id") @db.Uuid
  requestType     String                     @default("FULL_RECORD") @map("request_type") @db.VarChar(50)
  reason          String?                    @db.VarChar(500)
  status          MedicalRecordRequestStatus @default(PENDING)
  reviewedById    String?                    @map("reviewed_by_id") @db.Uuid
  reviewedAt      DateTime?                  @map("reviewed_at")
  reviewNotes     String?                    @map("review_notes") @db.VarChar(500)
  createdAt       DateTime                   @default(now()) @map("created_at")
  updatedAt       DateTime                   @updatedAt @map("updated_at")

  tenant     Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  patient    Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  reviewedBy User?   @relation("MedRecordReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([tenantId, patientId])
  @@index([tenantId, status])
  @@map("medical_record_requests")
}

enum MedicalRecordRequestStatus {
  PENDING
  APPROVED
  DENIED
  FULFILLED
}
