// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  branches           Branch[]
  users              User[]
  patients           Patient[]
  roles              Role[]
  permissions        Permission[]
  approvalRequests   ApprovalRequest[]
  notifications      Notification[]
  files              File[]
  cashierSessions    CashierSession[]
  numberingSequences NumberingSequence[]
  orders             Order[]
  auditLogs          AuditLog[]
  inventoryItems     InventoryItem[]
  branchStocks       BranchStock[]
  stockLogs          StockLog[]
  departments        Department[]
  employees          Employee[]
  employeeBranches   EmployeeBranch[]
  payslips           Payslip[]
  queueEntries       QueueEntry[]
  hmoPartners        HmoPartner[]
  claims             Claim[]
  userBranches       UserBranch[]
  reportExports       ReportExport[]
  patientMergeRequests PatientMergeRequest[]
  idempotencyRecords IdempotencyRecord[]

  @@map("tenants")
}

model Branch {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  name      String
  code      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant           Tenant           @relation(fields: [tenantId], references: [id])
  orders           Order[]
  userBranches     UserBranch[]
  branchStocks     BranchStock[]
  stockLogs        StockLog[]
  employeeBranches EmployeeBranch[]
  payslips         Payslip[]

  @@map("branches")
}

model User {
  id                String    @id @default(uuid()) @db.Uuid
  tenantId          String    @map("tenant_id") @db.Uuid
  email             String
  passwordHash      String    @map("password_hash")
  isMfaEnabled      Boolean   @default(false) @map("is_mfa_enabled")
  status            String    @default("ACTIVE")
  deactivatedAt     DateTime? @map("deactivated_at")
  deactivatedReason String?   @map("deactivated_reason")
  tokenVersion      Int       @default(0) @map("token_version")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  tenant             Tenant            @relation(fields: [tenantId], references: [id])
  auditLogs          AuditLog[]
  userRoles          UserRole[]
  userBranches       UserBranch[]
  reportExports      ReportExport[]    @relation("RequestedExports")
  decidedExports     ReportExport[]    @relation("DecidedExports")
  requestedApprovals ApprovalRequest[] @relation("RequestedApprovals")
  approvedApprovals  ApprovalRequest[] @relation("ApprovedApprovals")
  mergeRequested     PatientMergeRequest[] @relation("MergeRequested")
  mergeApproved      PatientMergeRequest[] @relation("MergeApproved")

  @@unique([tenantId, email])
  @@map("users")
}

model Role {
  id             String    @id @default(uuid()) @db.Uuid
  tenantId       String    @map("tenant_id") @db.Uuid
  name           String
  status         String    @default("ACTIVE")
  isSystem       Boolean   @default(false) @map("is_system")
  archivedAt     DateTime? @map("archived_at")
  archivedReason String?   @map("archived_reason")

  tenant          Tenant           @relation(fields: [tenantId], references: [id])
  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@map("roles")
}

model UserRole {
  userId        String    @map("user_id") @db.Uuid
  roleId        String    @map("role_id") @db.Uuid
  status        String    @default("ACTIVE")
  revokedAt     DateTime? @map("revoked_at")
  revokedReason String?   @map("revoked_reason")

  user User @relation(fields: [userId], references: [id])
  role Role @relation(fields: [roleId], references: [id])

  @@id([userId, roleId])
  @@map("user_roles")
}

model UserBranch {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  branchId  String   @map("branch_id") @db.Uuid
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId, branchId])
  @@index([tenantId])
  @@index([userId])
  @@index([branchId])
  @@index([tenantId, userId])
  @@index([tenantId, branchId])
  @@map("user_branches")
}

model Patient {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  patientNumber String   @map("patient_number")
  firstName     String   @map("first_name")
  lastName      String   @map("last_name")
  dob           DateTime @db.Date
  status        String   @default("ACTIVE")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  tenant Tenant  @relation(fields: [tenantId], references: [id])
  orders Order[]

  @@unique([tenantId, patientNumber])
  @@map("patients")
}

model Order {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  branchId    String   @map("branch_id") @db.Uuid
  patientId   String   @map("patient_id") @db.Uuid
  orderNumber String   @map("order_number")
  status      String   @default("DRAFT")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  branch    Branch     @relation(fields: [branchId], references: [id])
  patient   Patient    @relation(fields: [patientId], references: [id])
  invoice   Invoice?
  labResult LabResult?

  @@map("orders")
}

model Invoice {
  id            String   @id @default(uuid()) @db.Uuid
  orderId       String   @unique @map("order_id") @db.Uuid
  invoiceNumber String?  @unique @map("invoice_number")
  totalAmount   Decimal  @map("total_amount") @db.Decimal(12, 2)
  paidAmount    Decimal  @default(0) @map("paid_amount") @db.Decimal(12, 2)
  status        String   @default("UNPAID")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  order     Order             @relation(fields: [orderId], references: [id])
  payments  Payment[]
  reversals PaymentReversal[]
  claims    Claim[]

  @@map("invoices")
}

model Payment {
  id               String   @id @default(uuid()) @db.Uuid
  invoiceId        String   @map("invoice_id") @db.Uuid
  cashierSessionId String   @map("cashier_session_id") @db.Uuid
  receiptNumber    String?  @unique @map("receipt_number")
  amount           Decimal  @db.Decimal(12, 2)
  paymentMethod    String   @map("payment_method")
  status           String   @default("POSTED")
  idempotencyKey   String   @unique @map("idempotency_key")
  createdAt        DateTime @default(now()) @map("created_at")

  invoice        Invoice           @relation(fields: [invoiceId], references: [id])
  cashierSession CashierSession    @relation(fields: [cashierSessionId], references: [id])
  reversals      PaymentReversal[]

  @@map("payments")
}

model IdempotencyRecord {
  id                String   @id @default(uuid()) @db.Uuid
  tenantId          String   @map("tenant_id") @db.Uuid
  operation         String // BILLING_PAYMENT_POST
  key               String
  requestFingerprint String  @map("request_fingerprint") // Hash of normalized request
  status            String   @default("IN_PROGRESS") // IN_PROGRESS, COMPLETED, FAILED
  paymentId         String?  @map("payment_id") @db.Uuid // Set after successful payment creation
  responseData      Json?    @map("response_data") // Cached response for replay
  error             String?
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, operation, key])
  @@index([tenantId])
  @@index([status])
  @@map("idempotency_records")
}

model LabResult {
  id           String    @id @default(uuid()) @db.Uuid
  orderId      String    @unique @map("order_id") @db.Uuid
  status       String    @default("PENDING_COLLECTION")
  approvedById String?   @map("approved_by_id") @db.Uuid
  lockedAt     DateTime? @map("locked_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  order    Order              @relation(fields: [orderId], references: [id])
  versions LabResultVersion[]

  @@map("lab_results")
}

model LabResultVersion {
  id          String   @id @default(uuid()) @db.Uuid
  labResultId String   @map("lab_result_id") @db.Uuid
  version     Int      @default(1)
  oldStatus   String   @map("old_status")
  newStatus   String   @map("new_status")
  amendedById String   @map("amended_by_id") @db.Uuid
  reason      String
  oldData     Json?    @map("old_data") // Stores the previous results snapshot
  createdAt   DateTime @default(now()) @map("created_at")

  labResult LabResult @relation(fields: [labResultId], references: [id])

  @@map("lab_result_versions")
}

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  branchId   String?  @map("branch_id") @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  eventKey   String   @map("event_key")
  recordType String   @map("record_type")
  recordId   String   @map("record_id") @db.Uuid
  oldValues  Json?    @map("old_values")
  newValues  Json?    @map("new_values")
  createdAt  DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@index([tenantId])
  @@index([branchId])
  @@map("audit_logs")
}

// --- MODULE 4: INVENTORY & PHARMACY ---

model InventoryItem {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  name         String
  sku          String?
  category     String // DRUG, SUPPLY, EQUIPMENT
  unit         String // TABLET, BOX, PIECE
  reorderLevel Int      @default(10) @map("reorder_level")
  currentStock Int      @default(0) @map("current_stock")
  price        Decimal  @db.Decimal(12, 2)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  stockLogs    StockLog[]
  branchStocks BranchStock[]

  @@unique([tenantId, sku])
  @@map("inventory_items")
}

model BranchStock {
  id              String   @id @default(uuid()) @db.Uuid
  tenantId        String   @map("tenant_id") @db.Uuid
  branchId        String   @map("branch_id") @db.Uuid
  inventoryItemId String   @map("inventory_item_id") @db.Uuid
  quantity        Int      @default(0)
  reorderLevel    Int      @default(10) @map("reorder_level")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  tenant        Tenant        @relation(fields: [tenantId], references: [id])
  branch        Branch        @relation(fields: [branchId], references: [id])
  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id])

  @@unique([tenantId, branchId, inventoryItemId])
  @@index([tenantId])
  @@index([branchId])
  @@index([inventoryItemId])
  @@index([tenantId, branchId])
  @@map("branch_stocks")
}

model StockLog {
  id              String   @id @default(uuid()) @db.Uuid
  tenantId        String   @map("tenant_id") @db.Uuid
  branchId        String   @map("branch_id") @db.Uuid
  inventoryItemId String   @map("inventory_item_id") @db.Uuid
  type            String // IN, OUT, ADJUSTMENT, RETURN
  quantity        Int
  previousStock   Int      @map("previous_stock")
  newStock        Int      @map("new_stock")
  referenceType   String?  @map("reference_type") // PURCHASE_ORDER, DISPENSING
  referenceId     String?  @map("reference_id") @db.Uuid
  remarks         String?
  createdAt       DateTime @default(now()) @map("created_at")

  tenant Tenant        @relation(fields: [tenantId], references: [id])
  branch Branch        @relation(fields: [branchId], references: [id])
  item   InventoryItem @relation(fields: [inventoryItemId], references: [id])

  @@map("stock_logs")
}

// --- MODULE 5: HUMAN RESOURCES & PAYROLL ---
// DEFERRED: HR & Payroll module not currently wired/supported. Do not implement.

model Department {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  name      String
  code      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  employees Employee[]

  @@unique([tenantId, code])
  @@map("departments")
}

model Employee {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  departmentId   String?  @map("department_id") @db.Uuid
  employeeNumber String   @map("employee_number")
  firstName      String   @map("first_name")
  lastName       String   @map("last_name")
  jobTitle       String   @map("job_title")
  status         String   @default("ACTIVE") // ACTIVE, INACTIVE, SUSPENDED
  joiningDate    DateTime @map("joining_date") @db.Date
  salary         Decimal  @db.Decimal(12, 2)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  tenant           Tenant           @relation(fields: [tenantId], references: [id])
  department       Department?      @relation(fields: [departmentId], references: [id])
  employeeBranches EmployeeBranch[]
  payslips         Payslip[]

  @@unique([tenantId, employeeNumber])
  @@map("employees")
}

model EmployeeBranch {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  employeeId String   @map("employee_id") @db.Uuid
  branchId   String   @map("branch_id") @db.Uuid
  isPrimary  Boolean  @default(false) @map("is_primary")
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  branch   Branch   @relation(fields: [branchId], references: [id], onDelete: Restrict)

  @@unique([tenantId, employeeId, branchId])
  @@index([tenantId])
  @@index([employeeId])
  @@index([branchId])
  @@index([tenantId, branchId])
  @@index([tenantId, employeeId])
  @@map("employee_branches")
}

model Payslip {
  id              String   @id @default(uuid()) @db.Uuid
  tenantId        String   @map("tenant_id") @db.Uuid
  branchId        String   @map("branch_id") @db.Uuid
  employeeId      String   @map("employee_id") @db.Uuid
  periodStart     DateTime @map("period_start") @db.Date
  periodEnd       DateTime @map("period_end") @db.Date
  basicSalary     Decimal  @map("basic_salary") @db.Decimal(12, 2)
  totalAllowances Decimal  @map("total_allowances") @db.Decimal(12, 2)
  totalDeductions Decimal  @map("total_deductions") @db.Decimal(12, 2)
  netSalary       Decimal  @map("net_salary") @db.Decimal(12, 2)
  status          String   @default("DRAFT") // DRAFT, PAID
  createdAt       DateTime @default(now()) @map("created_at")

  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  branch   Branch   @relation(fields: [branchId], references: [id])
  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([tenantId, branchId])
  @@index([tenantId, employeeId, branchId])
  @@map("payslips")
}

// --- MODULE 10: QUEUEING & PATIENT FLOW ---

model QueueEntry {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  branchId      String   @map("branch_id") @db.Uuid
  patientId     String?  @map("patient_id") @db.Uuid
  patientName   String?  @map("patient_name")
  queueNumber   String   @map("queue_number")
  category      String   @default("REGULAR") // REGULAR, PRIORITY, EMERGENCY
  serviceType   String   @map("service_type") // RECEPTION, CASHIER, LABORATORY, DOCTOR
  status        String   @default("WAITING") // WAITING, CALLING, SERVING, COMPLETED, CANCELLED
  counterNumber String?  @map("counter_number")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@map("queue_entries")
}

// --- MODULE 11: HMO & PHILHEALTH CLAIMS ---

model HmoPartner {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  name          String
  code          String
  contactPerson String?  @map("contact_person")
  email         String?
  status        String   @default("ACTIVE")
  createdAt     DateTime @default(now()) @map("created_at")

  tenant Tenant  @relation(fields: [tenantId], references: [id])
  claims Claim[]

  @@unique([tenantId, code])
  @@map("hmo_partners")
}

model Claim {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  hmoPartnerId   String   @map("hmo_partner_id") @db.Uuid
  invoiceId      String   @map("invoice_id") @db.Uuid
  claimNumber    String   @map("claim_number")
  loaNumber      String?  @map("loa_number")
  amountClaimed  Decimal  @map("amount_claimed") @db.Decimal(12, 2)
  amountApproved Decimal? @map("amount_approved") @db.Decimal(12, 2)
  status         String   @default("PENDING") // PENDING, SUBMITTED, APPROVED, DENIED, PAID
  remarks        String?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  tenant     Tenant     @relation(fields: [tenantId], references: [id])
  hmoPartner HmoPartner @relation(fields: [hmoPartnerId], references: [id])
  invoice    Invoice    @relation(fields: [invoiceId], references: [id])

  @@unique([tenantId, claimNumber])
  @@map("claims")
}

// --- MODULE: FOUNDATION & SECURITY ---

model PaymentReversal {
  id                String    @id @default(uuid()) @db.Uuid
  tenantId          String    @map("tenant_id") @db.Uuid
  branchId          String    @map("branch_id") @db.Uuid
  paymentId         String    @map("payment_id") @db.Uuid
  invoiceId         String    @map("invoice_id") @db.Uuid
  approvalRequestId String    @unique @map("approval_request_id") @db.Uuid
  amount            Decimal   @db.Decimal(12, 2)
  type              String // REFUND, PAYMENT_VOID
  status            String    @default("PENDING") // PENDING, APPLIED, REJECTED, CANCELLED
  reason            String
  requestedBy       String    @map("requested_by") @db.Uuid
  approvedBy        String?   @map("approved_by") @db.Uuid
  appliedBy         String?   @map("applied_by") @db.Uuid
  requestedAt       DateTime  @default(now()) @map("requested_at")
  approvedAt        DateTime? @map("approved_at")
  appliedAt         DateTime? @map("applied_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  payment         Payment         @relation(fields: [paymentId], references: [id])
  invoice         Invoice         @relation(fields: [invoiceId], references: [id])
  approvalRequest ApprovalRequest @relation(fields: [approvalRequestId], references: [id])

  @@index([tenantId])
  @@index([branchId])
  @@index([paymentId])
  @@index([invoiceId])
  @@index([status])
  @@index([type])
  @@map("payment_reversals")
}

model Permission {
  id        String  @id @default(uuid()) @db.Uuid
  tenantId  String  @map("tenant_id") @db.Uuid
  name      String // e.g. patient.view, billing.refund.approve
  scope     String? // e.g. branch, department, tenant
  riskLevel String  @default("PRIVILEGED") @map("risk_level")

  tenant          Tenant           @relation(fields: [tenantId], references: [id])
  rolePermissions RolePermission[]

  @@unique([tenantId, name])
  @@map("permissions")
}

model RolePermission {
  roleId       String @map("role_id") @db.Uuid
  permissionId String @map("permission_id") @db.Uuid

  role       Role       @relation(fields: [roleId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model ApprovalRequest {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  requesterId String   @map("requester_id") @db.Uuid
  approverId  String?  @map("approver_id") @db.Uuid
  type        String // e.g. REFUND, ROLE_CHANGE, RESULT_AMENDMENT
  riskLevel   String // LOW, MEDIUM, HIGH, CRITICAL
  recordId    String   @map("record_id")
  status      String   @default("PENDING") // PENDING, APPROVED, REJECTED, APPLIED
  reason      String?
  remarks     String?
  details     Json?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant           Tenant            @relation(fields: [tenantId], references: [id])
  requester        User              @relation("RequestedApprovals", fields: [requesterId], references: [id])
  approver         User?             @relation("ApprovedApprovals", fields: [approverId], references: [id])
  paymentReversals PaymentReversal[]

  @@map("approval_requests")
}

model Notification {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  userId      String?   @map("user_id") @db.Uuid
  patientId   String?   @map("patient_id") @db.Uuid
  type        String // SMS, EMAIL, IN_APP
  status      String    @default("PENDING") // PENDING, SENT, FAILED, READ, CANCELLED
  recipient   String
  subject     String?
  content     String // Keep this safe (no PHI based on rules)
  templateKey String?   @map("template_key")
  category    String    @default("SYSTEM") // SYSTEM, ALERT, APPROVAL, RESULT, PAYMENT, SECURITY
  priority    String    @default("NORMAL") // LOW, NORMAL, HIGH, CRITICAL
  attempts    Int       @default(0)
  lastError   String?   @map("last_error")
  sentAt      DateTime? @map("sent_at")
  readAt      DateTime? @map("read_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@map("notifications")
}

model File {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  recordType   String   @map("record_type") // e.g. Patient, LabResult
  recordId     String   @map("record_id") @db.Uuid
  fileName     String   @map("file_name")
  fileSize     Int      @map("file_size")
  mimeType     String   @map("mime_type")
  storagePath  String   @map("storage_path")
  uploadedById String   @map("uploaded_by_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@map("files")
}

model CashierSession {
  id             String    @id @default(uuid()) @db.Uuid
  tenantId       String    @map("tenant_id") @db.Uuid
  branchId       String    @map("branch_id") @db.Uuid
  userId         String    @map("user_id") @db.Uuid
  status         String    @default("OPEN") // OPEN, PENDING_REVIEW, CLOSED
  openingBalance Decimal   @map("opening_balance") @db.Decimal(12, 2)
  closingBalance Decimal?  @map("closing_balance") @db.Decimal(12, 2)
  openedAt       DateTime  @default(now()) @map("opened_at")
  closedAt       DateTime? @map("closed_at")

  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  payments Payment[]

  @@map("cashier_sessions")
}

model NumberingSequence {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  branchId   String?  @map("branch_id") @db.Uuid // Optional, for branch-specific sequences
  entityType String   @map("entity_type") // e.g., PATIENT, INVOICE, RECEIPT, ORDER
  prefix     String
  currentVal Int      @default(0) @map("current_val")
  padding    Int      @default(6) // e.g., 6 -> 000001
  updatedAt  DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, branchId, entityType])
  @@map("numbering_sequences")
}

model ReportExport {
  id                  String    @id @default(uuid()) @db.Uuid
  tenantId            String    @map("tenant_id") @db.Uuid
  branchId            String?   @map("branch_id") @db.Uuid
  reportType          String    @map("report_type")
  filters             Json
  reason              String
  rowCount            Int       @map("row_count")
  status              String    @default("PENDING_APPROVAL") // PENDING_APPROVAL, APPROVED, REJECTED, FAILED
  riskLevel           String    @default("HIGH") @map("risk_level") // LOW, MEDIUM, HIGH, PRIVILEGED
  format              String?
  filtersSnapshot     Json?     @map("filters_snapshot")
  fieldPolicySnapshot Json?     @map("field_policy_snapshot")
  requestedFields     Json?     @map("requested_fields")
  allowedFields       Json?     @map("allowed_fields")
  maskedFields        Json?     @map("masked_fields")
  requestedBy         String    @map("requested_by") @db.Uuid
  decidedById         String?   @map("decided_by_id") @db.Uuid
  decidedAt           DateTime? @map("decided_at")
  decisionReason      String?   @map("decision_reason")
  createdAt           DateTime  @default(now()) @map("created_at")
  completedAt         DateTime? @map("completed_at")
  approvedAt          DateTime? @map("approved_at") // deprecated, use decidedAt
  generatedAt         DateTime? @map("generated_at")
  expiresAt           DateTime? @map("expires_at")
  storageKey          String?   @map("storage_key")
  checksum            String?
  downloadCount       Int       @default(0) @map("download_count")
  lastDownloadedAt    DateTime? @map("last_downloaded_at")
  failureReason       String?   @map("failure_reason")

  tenant    Tenant  @relation(fields: [tenantId], references: [id])
  user      User    @relation("RequestedExports", fields: [requestedBy], references: [id])
  decider   User?   @relation("DecidedExports", fields: [decidedById], references: [id])

  @@index([tenantId])
  @@index([branchId])
  @@map("report_exports")
}

model PatientMergeRequest {
  id              String   @id @default(uuid()) @db.Uuid
  tenantId        String   @map("tenant_id") @db.Uuid
  branchId        String?  @map("branch_id") @db.Uuid
  requesterId     String   @map("requester_id") @db.Uuid
  approverId      String?  @map("approver_id") @db.Uuid
  sourcePatientId String   @map("source_patient_id") @db.Uuid
  targetPatientId String   @map("target_patient_id") @db.Uuid
  status          String   @default("PENDING")  // PENDING, APPROVED, REJECTED
  reason          String   // Why merge is needed
  remarks         String?  // Approver comments
  riskLevel       String   @default("HIGH")     // Patient merge is always HIGH risk
  fieldSnapshots  Json?    @map("field_snapshots")  // Snapshots of conflicting fields
  appliedAt       DateTime? @map("applied_at")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  tenant    Tenant @relation(fields: [tenantId], references: [id])
  requester User   @relation("MergeRequested", fields: [requesterId], references: [id])
  approver  User?  @relation("MergeApproved", fields: [approverId], references: [id])

  @@index([tenantId])
  @@index([branchId])
  @@index([status])
  @@map("patient_merge_requests")
}
