import { Pool } from 'pg';
import { PrismaPg } from '@prisma/adapter-pg';
import { PrismaClient } from '@prisma/client';
import * as bcrypt from 'bcrypt';

const pool = new Pool({ connectionString: process.env.DATABASE_URL });
const adapter = new PrismaPg(pool);
const prisma = new PrismaClient({ adapter });

async function main() {
  console.log('Seeding Nurse role and user...');

  const tenantId = '00000000-0000-0000-0000-000000000001';
  const branchId = '00000000-0000-0000-0000-000000000010';

  // 1. Ensure Nurse role exists
  const roleId = '00000000-0000-0000-0000-000000000008';
  const role = await prisma.role.upsert({
    where: { id: roleId },
    update: { status: 'ACTIVE', isSystem: true },
    create: {
      id: roleId,
      tenantId,
      name: 'Nurse',
      status: 'ACTIVE',
      isSystem: true,
    },
  });
  console.log('Nurse role registered.');

  // 2. Map permissions for Nurse role
  const allPerms = await prisma.permission.findMany({ where: { tenantId } });
  const nursePermNames = [
    'patient.view', 'patient.create', 'patient.update',
    'order.view', 'order.create',
    'billing.invoice.view', 'billing.claim.view',
    'inventory.item.view', 'inventory.stock.receive', 'inventory.stock.dispense',
    'queue.view', 'queue.manage',
    'encounter.create', 'encounter.view', 'encounter.update'
  ];

  for (const permName of nursePermNames) {
    const permission = allPerms.find(p => p.name === permName);
    if (!permission) continue;

    await prisma.rolePermission.upsert({
      where: {
        roleId_permissionId: {
          roleId: role.id,
          permissionId: permission.id,
        },
      },
      update: {},
      create: {
        roleId: role.id,
        permissionId: permission.id,
      },
    });
  }
  console.log('Nurse permissions mapped.');

  // 2a. Ensure Analyst role exists
  const analystRoleId = '00000000-0000-0000-0000-000000000009';
  const analystRole = await prisma.role.upsert({
    where: { id: analystRoleId },
    update: { status: 'ACTIVE', isSystem: true },
    create: {
      id: analystRoleId,
      tenantId,
      name: 'Analyst',
      status: 'ACTIVE',
      isSystem: true,
    },
  });
  console.log('Analyst role registered.');

  // Map permissions for Analyst role
  const analystPermNames = [
    'billing.invoice.view', 'billing.claim.view',
    'report.export', 'audit.view'
  ];

  for (const permName of analystPermNames) {
    const permission = allPerms.find(p => p.name === permName);
    if (!permission) continue;

    await prisma.rolePermission.upsert({
      where: {
        roleId_permissionId: {
          roleId: analystRole.id,
          permissionId: permission.id,
        },
      },
      update: {},
      create: {
        roleId: analystRole.id,
        permissionId: permission.id,
      },
    });
  }
  console.log('Analyst permissions mapped.');

  // 3. Create Nurse User
  const passwordHash = await bcrypt.hash('Admin@123', 10);
  const user = await prisma.user.upsert({
    where: {
      tenantId_email: {
        tenantId,
        email: 'nurse@hospital.com',
      },
    },
    update: { passwordHash },
    create: {
      tenantId,
      email: 'nurse@hospital.com',
      passwordHash,
      mfaEnabled: false,
    },
  });
  console.log('Nurse user created: nurse@hospital.com');

  // 3a. Create Analyst User
  const analystUser = await prisma.user.upsert({
    where: {
      tenantId_email: {
        tenantId,
        email: 'analyst@hospital.com',
      },
    },
    update: { passwordHash },
    create: {
      tenantId,
      email: 'analyst@hospital.com',
      passwordHash,
      mfaEnabled: false,
    },
  });
  console.log('Analyst user created: analyst@hospital.com');

  // 4. Link User to Role
  await prisma.userRole.upsert({
    where: {
      userId_roleId: {
        userId: user.id,
        roleId: role.id,
      },
    },
    update: {},
    create: {
      userId: user.id,
      roleId: role.id,
    },
  });

  // 4a. Link Analyst User to Role
  await prisma.userRole.upsert({
    where: {
      userId_roleId: {
        userId: analystUser.id,
        roleId: analystRole.id,
      },
    },
    update: {},
    create: {
      userId: analystUser.id,
      roleId: analystRole.id,
    },
  });

  // 5. Assign user to default Branch
  await prisma.userBranch.upsert({
    where: {
      tenantId_userId_branchId: {
        tenantId,
        userId: user.id,
        branchId,
      },
    },
    update: {},
    create: {
      tenantId,
      userId: user.id,
      branchId,
      isActive: true,
    },
  });
  console.log('Nurse linked to default branch.');

  // 5a. Assign analyst user to default Branch
  await prisma.userBranch.upsert({
    where: {
      tenantId_userId_branchId: {
        tenantId,
        userId: analystUser.id,
        branchId,
      },
    },
    update: {},
    create: {
      tenantId,
      userId: analystUser.id,
      branchId,
      isActive: true,
    },
  });
  console.log('Analyst linked to default branch.');

  // 6. Create default B2B Commerce & Field Logistics mock data
  console.log('Seeding mock B2B Assets and Installation Jobs...');
  
  // Idempotency Cleanup
  await prisma.installationJob.deleteMany();
  await prisma.asset.deleteMany();
  await prisma.salesOrder.deleteMany();
  await prisma.quote.deleteMany();
  await prisma.rFQ.deleteMany();
  
  // Create RFQ
  const rfq = await prisma.rFQ.create({
    data: {
      tenantId,
      branchId,
      title: 'MRI Installation Suite Procurement',
      status: 'APPROVED',
    },
  });

  // Create Quote
  const quote = await prisma.quote.create({
    data: {
      rfqId: rfq.id,
      tenantId,
      status: 'ACCEPTED',
      totalAmount: 1250000.00,
      convertedAt: new Date(),
    },
  });

  // Create SalesOrder
  const salesOrder = await prisma.salesOrder.create({
    data: {
      quoteId: quote.id,
      tenantId,
      status: 'COMPLETED',
    },
  });

  // Create Assets
  const asset1 = await prisma.asset.create({
    data: {
      salesOrderId: salesOrder.id,
      tenantId,
      serialNumber: 'MRI-7000-VOLT-A9',
      model: 'General Electric Signa 3.0T MRI Scanner',
      installationStatus: 'PENDING_ASSESSMENT',
    },
  });

  const asset2 = await prisma.asset.create({
    data: {
      salesOrderId: salesOrder.id,
      tenantId,
      serialNumber: 'CT-9000-SLICE-Z1',
      model: 'Siemens Somatom Force dual-source CT',
      installationStatus: 'SITE_READY',
    },
  });

  // Create Installation Jobs assigned to our nurse user
  await prisma.installationJob.create({
    data: {
      assetId: asset1.id,
      assignedUserId: user.id,
      status: 'ASSIGNED',
    },
  });

  await prisma.installationJob.create({
    data: {
      assetId: asset2.id,
      assignedUserId: user.id,
      status: 'IN_PROGRESS',
    },
  });

  console.log('Mock installation jobs and B2B assets seeded successfully!');
}

main()
  .catch((e) => {
    console.error(e);
    process.exit(1);
  })
  .finally(async () => {
    await prisma.$disconnect();
  });
